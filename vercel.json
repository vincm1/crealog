{
  "build": {
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://app.storyblok.com"
        }
      ]
    }
  ]
}
