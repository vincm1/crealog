---
import { storyblokEditable } from "@storyblok/astro";
const { blok } = Astro.props;
---

<div {...storyblokEditable(blok)} class="flex flex-col items-center text-center gap-1">
  <span class="text-4xl lg:text-5xl font-bold text-white">{blok.value}</span>
  <span class="text-sm font-medium text-blue-200">{blok.label}</span>
</div>
