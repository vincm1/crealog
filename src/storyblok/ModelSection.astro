---
import { storyblokEditable } from "@storyblok/astro";
const { blok } = Astro.props;

const eyebrow = blok.eyebrow || "Unser Modell";
const headlineBefore = blok.headline_before || "";
const headlineHighlight = blok.headline_highlight || "";
const headlineAfter = blok.headline_after || "";

const features = Array.isArray(blok.features) ? blok.features : [];
const steps = Array.isArray(blok.steps) ? blok.steps : [];
const stepsEyebrow = blok.steps_eyebrow || "So funktioniert's";
---

<section {...storyblokEditable(blok)} class="model-section">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">

    <!-- ===== Our Model ===== -->
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left: eyebrow + headline + buttons -->
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h2 class="model-headline">
          {headlineBefore}
          {headlineHighlight && <mark class="hl">{headlineHighlight}</mark>}
          {headlineAfter}
        </h2>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          {blok.cta_primary_text && (
            <a href={blok.cta_primary_href || "#"} class="btn-primary">
              {blok.cta_primary_text}
            </a>
          )}
          {blok.cta_secondary_text && (
            <a href={blok.cta_secondary_href || "#"} class="btn-outline">
              {blok.cta_secondary_text}
            </a>
          )}
        </div>
      </div>

      <!-- Right: spec list (2 columns, hairline rows) -->
      {features.length > 0 && (
        <div class="grid grid-cols-1 gap-x-10 gap-y-7 sm:grid-cols-2">
          {features.map((f: any) => (
            <div {...storyblokEditable(f)} class="spec-cell">
              <h3 class="spec-title">{f.title}</h3>
              {f.description && <p class="spec-desc">{f.description}</p>}
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- ===== How it works ===== -->
    {steps.length > 0 && (
      <div class="mt-20 lg:mt-28">
        <p class="eyebrow">{stepsEyebrow}</p>
        <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {steps.map((s: any, i: number) => (
            <div {...storyblokEditable(s)} class="step-card">
              <div class="step-badge">{i + 1}</div>
              <h3 class="step-title">{s.title}</h3>
              {s.description && <p class="step-desc">{s.description}</p>}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .model-section {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: #ffffff;
    padding: 6rem 0;
    color: #0f1e30;
  }

  /* Eyebrow label — CreaLog navy, uppercase tracked */
  .eyebrow {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #004990;
  }

  .model-headline {
    margin: 1.25rem 0 0;
    max-width: 22ch;
    font-size: clamp(1.6rem, 2.6vw, 2.25rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: #0f1e30;
  }

  /* Highlighted phrase — CreaLog amber */
  .hl {
    background: #fcb040;
    color: #0f1e30;
    padding: 0 0.18em;
    border-radius: 3px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  /* Buttons — CreaLog colours */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.6rem;
    border-radius: 9999px;
    background: #004990;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-primary:hover {
    background: #013a73;
    transform: translateY(-1px);
    box-shadow: 0 10px 26px rgba(0, 73, 144, 0.28);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.6rem;
    border-radius: 9999px;
    background: #fff;
    color: #0f1e30;
    border: 1px solid #d7dee8;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .btn-outline:hover {
    border-color: #004990;
    color: #004990;
    transform: translateY(-1px);
  }

  /* Spec list (right column) */
  .spec-cell {
    border-top: 1px solid #e2e8f0;
    padding-top: 1.15rem;
  }
  .spec-title {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: #0f1e30;
  }
  .spec-desc {
    margin: 0.5rem 0 0;
    font-size: 14px;
    line-height: 1.6;
    color: #64748b;
  }

  /* How it works — navy cards with amber number badge */
  .step-card {
    background: #004990;
    border-radius: 18px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: 200px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .step-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 36px -16px rgba(0, 73, 144, 0.6);
  }
  .step-badge {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 12px;
    background: #fcb040;
    color: #0f1e30;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    flex: none;
  }
  .step-title {
    margin: 0.35rem 0 0;
    font-size: 16px;
    font-weight: 700;
    color: #ffffff;
  }
  .step-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-primary, .btn-outline, .step-card { transition: none; }
    .btn-primary:hover, .btn-outline:hover, .step-card:hover { transform: none; }
  }
</style>
