---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;

const leaders = [
  {
    name: "Michael Kloos",
    role: "Geschäftsführer",
    quote: "Seit fast drei Jahrzehnten gestalten wir die Zukunft des Kundenkontakts - mit Technologie, die Menschen in den Mittelpunkt stellt.",
    image: "/management/michael_kloos.jpg",
  },
  {
    name: "Bernd Plannerer",
    role: "Geschäftsführer",
    quote: "Unsere Stärke liegt in der Verbindung von tiefer Technologieexpertise und echtem Verständnis für die Bedürfnisse unserer Kunden.",
    image: "/management/bernd_plannerer.png",
  },
];
---

<section {...storyblokEditable(blok)} class="management-section bg-white py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="mb-14 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <div class="section-eyebrow">
          <div class="section-eyebrow__line"></div>
          <span>Management</span>
        </div>
        <h2 class="section-title">
          Führung mit
          <span class="section-title__accent">technischer Tiefe</span>
        </h2>
        <p class="section-sub">
          CreaLog ist kein generisches Software-Haus. Die Geschäftsführung verbindet Carrier-Realität, Produktdenken und langfristige Verantwortung.
        </p>
      </div>

      <div class="management-facts">
        <span>1993 gegründet</span>
        <span>2 Geschäftsführer</span>
        <span>Made in Germany</span>
      </div>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {leaders.map((leader, index) => (
        <article
          class={`leader-card reveal ${index === 1 ? "md:translate-y-6" : ""}`}
          style={`transition-delay: ${index * 110}ms`}
        >
          <div class="leader-card__inner">
            <div class="leader-card__media">
              <img src={leader.image} alt={leader.name} loading="lazy" />
              <div class="leader-card__shade"></div>
            </div>
            <div class="leader-card__body">
              <div class="leader-role">{leader.role}</div>
              <h3>{leader.name}</h3>
              <p>{leader.quote}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .management-section {
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1rem;
  }

  .section-eyebrow__line {
    width: 24px;
    height: 1px;
    background: #1d6bbf;
    flex-shrink: 0;
  }

  .section-eyebrow span {
    color: #1d6bbf;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.28em;
  }

  .section-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: #0a1628;
  }

  .section-title__accent {
    color: #1d6bbf;
  }

  .section-sub {
    margin: 1rem 0 0;
    max-width: 48rem;
    font-size: 15px;
    line-height: 1.7;
    color: #5b6472;
  }

  .management-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .management-facts span {
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid #e2e8f0;
    background: #f8faff;
    color: #475569;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .leader-card {
    position: relative;
    overflow: hidden;
    border-radius: 2rem;
    border: 1px solid rgba(219, 229, 242, 0.95);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 249, 253, 0.98) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 24px 60px rgba(10, 22, 40, 0.08);
  }

  .leader-card__inner {
    display: grid;
    gap: 1.25rem;
    align-items: center;
    padding: 1.1rem;
  }

  @media (min-width: 768px) {
    .leader-card__inner {
      grid-template-columns: minmax(0, 196px) minmax(0, 1fr);
      gap: 1.35rem;
      padding: 1.2rem;
    }
  }

  .leader-card__media {
    position: relative;
    aspect-ratio: 1 / 1.06;
    overflow: hidden;
    background: linear-gradient(180deg, #e9eff8 0%, #dbe5f2 100%);
    border-radius: 1.5rem;
    border: 1px solid rgba(219, 229, 242, 0.9);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.75),
      0 18px 35px rgba(10, 22, 40, 0.08);
  }

  .leader-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .leader-card__shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(7, 16, 29, 0.02) 0%, rgba(7, 16, 29, 0.08) 58%, rgba(7, 16, 29, 0.42) 100%),
      linear-gradient(90deg, rgba(29, 107, 191, 0.08) 0%, transparent 38%, transparent 100%);
  }

  .leader-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 0.15rem 0.2rem 0.35rem;
  }

  .leader-role {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.42rem 0.82rem;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d6bbf;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .leader-card__body h3 {
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.55rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: #0a1628;
  }

  .leader-card__body p {
    margin: 0;
    font-size: 14px;
    line-height: 1.72;
    color: #5b6472;
    max-width: 34ch;
  }

  @media (max-width: 767px) {
    .leader-card__media {
      max-height: 18rem;
    }
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>(".management-section");
  if (section) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const els = section.querySelectorAll<HTMLElement>(".reveal");

    if (reduce) {
      els.forEach((el) => el.classList.add("is-visible"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 },
      );

      els.forEach((el) => io.observe(el));
    }
  }
</script>
