---
import { storyblokEditable } from "@storyblok/astro";
const { blok } = Astro.props;

const bg: Record<string, string> = {
  blue: "bg-[#004990]",
  dark: "bg-[#09090b]",
  light: "bg-gray-50 border-t border-gray-100",
};
const textColor = blok.variant === "light" ? "text-gray-900" : "text-white";
const subColor = blok.variant === "light" ? "text-gray-500" : "text-blue-100";
const bgClass = bg[blok.variant] ?? bg.blue;
---

<section {...storyblokEditable(blok)} class={`${bgClass} py-20`}>
  <div class="max-w-3xl mx-auto px-6 lg:px-10 text-center">
    <h2 class={`text-2xl lg:text-3xl font-bold ${textColor} mb-4`}>{blok.title}</h2>
    {blok.subtitle && (
      <p class={`${subColor} mb-8 leading-relaxed`}>{blok.subtitle}</p>
    )}
    {blok.button_text && (
      <a
        href={blok.button_href || "/kontakt"}
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-[#004990] text-sm font-semibold rounded-full hover:bg-gray-50 transition-colors"
      >
        {blok.button_text}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    )}
  </div>
</section>
