---
import { storyblokEditable } from "@storyblok/astro";
import { Icon } from "astro-icon/components";
const { blok } = Astro.props;
---

<div {...storyblokEditable(blok)} class="fi-root">
  {blok.icon && (
    <div class="fi-icon">
      <Icon name={`heroicons:${blok.icon}`} class="fi-icon-svg" />
    </div>
  )}
  <h3 class="fi-title">{blok.title}</h3>
  {blok.description && (
    <p class="fi-desc">{blok.description}</p>
  )}
</div>

<style>
  .fi-root {
    font-family: "Plus Jakarta Sans", sans-serif;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .fi-icon {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: linear-gradient(145deg, #3b82f6 0%, #1d4ed8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
    margin-bottom: 1.25rem;
    box-shadow: 0 2px 10px rgba(37, 99, 235, 0.3);
  }

  .fi-icon [data-icon] {
    width: 21px;
    height: 21px;
    color: #ffffff;
  }

  .fi-title {
    margin: 0 0 0.55rem;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    color: #0a1628;
  }

  .fi-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.68;
    color: #6b7280;
  }
</style>
