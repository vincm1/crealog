---
import { storyblokEditable } from "@storyblok/astro";
import Icon from "../components/Icon.astro";
const { blok } = Astro.props;
---

<div {...storyblokEditable(blok)} class="bg-gray-50 rounded-2xl p-6 flex flex-col gap-3 hover:bg-gray-100 transition-colors">
  {blok.icon && (
    <div class="w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center flex-none">
      <Icon name={blok.icon} class="w-5 h-5 text-[#004990]" />
    </div>
  )}
  <h3 class="text-[15px] font-semibold text-gray-900">{blok.title}</h3>
  {blok.description && (
    <p class="text-[14px] text-gray-500 leading-relaxed flex-1">{blok.description}</p>
  )}
  {blok.link_text && blok.link_href && (
    <a
      href={blok.link_href}
      class="inline-flex items-center gap-1 text-[13px] font-medium text-[#004990] hover:text-[#1d4ed8] transition-colors mt-1"
    >
      {blok.link_text}
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  )}
</div>
