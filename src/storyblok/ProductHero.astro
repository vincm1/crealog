---
import { storyblokEditable } from "@storyblok/astro";
const { blok } = Astro.props;
---

<section
  {...storyblokEditable(blok)}
  class="relative pt-32 pb-20 bg-white overflow-hidden"
>
  <div class="max-w-4xl mx-auto px-6 lg:px-10 text-center">
    {blok.badge && (
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-[#004990] border border-blue-100 mb-6">
        {blok.badge}
      </span>
    )}

    <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 tracking-tight mb-4">
      {blok.title}
    </h1>

    {blok.tagline && (
      <p class="text-sm font-medium text-gray-400 tracking-wide uppercase mb-6">
        {blok.tagline}
      </p>
    )}

    {blok.subtitle && (
      <p class="text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto mb-10">
        {blok.subtitle}
      </p>
    )}

    <div class="flex flex-wrap items-center justify-center gap-3">
      {blok.cta_primary_text && (
        <a
          href={blok.cta_primary_href || "#"}
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#09090b] text-white text-sm font-semibold rounded-full hover:bg-[#18181b] transition-colors"
        >
          {blok.cta_primary_text}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      )}
      {blok.cta_secondary_text && (
        <a
          href={blok.cta_secondary_href || "#"}
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-gray-700 border border-gray-200 rounded-full hover:border-gray-300 hover:text-gray-900 transition-colors"
        >
          {blok.cta_secondary_text}
        </a>
      )}
    </div>
  </div>
</section>
