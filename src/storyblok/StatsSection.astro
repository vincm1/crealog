---
import { storyblokEditable } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
const { blok } = Astro.props;
---

<section {...storyblokEditable(blok)} class="py-16 bg-[#004990]">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    {(blok.title || blok.subtitle) && (
      <div class="text-center mb-12">
        {blok.title && <h2 class="text-2xl font-bold text-white mb-2">{blok.title}</h2>}
        {blok.subtitle && <p class="text-blue-200">{blok.subtitle}</p>}
      </div>
    )}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {blok.stats?.map((stat: any) => <StoryblokComponent blok={stat} />)}
    </div>
  </div>
</section>
