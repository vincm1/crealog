---
const logos = [
  // telekom png carries extra canvas + a "Germany" sub-label, so it needs more height to read evenly
  { src: "/customer_logos/telekom_logo.png", alt: "Deutsche Telekom", h: 52 },
  { src: "/customer_logos/logo-swisscom.svg", alt: "Swisscom", h: 50 },
  { src: "/customer_logos/a1_logo.jpg", alt: "A1 Telekom Austria", h: 40 },
  { src: "/customer_logos/sky_logo.png", alt: "Sky", h: 34 },
];
---

<style>
  .cl-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(3.5rem, 8vw, 7rem);
    padding: 0 1.5rem;
  }

  .cl-row img {
    width: auto;
    /* desaturate at rest (keeps the white JPG bg clean, unlike brightness(0));
       brand colour returns on hover */
    filter: grayscale(1) opacity(0.55);
    transition: filter 0.25s ease, transform 0.25s ease;
  }

  .cl-row img:hover {
    filter: grayscale(0) opacity(1);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .cl-row img:hover {
      transform: none;
    }
  }
</style>

<div class="cl-row">
  {logos.map((l) => <img src={l.src} alt={l.alt} style={`height:${l.h}px`} loading="lazy" />)}
</div>
