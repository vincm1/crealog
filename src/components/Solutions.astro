---
import SolutionsTabs from "./SolutionsTabs.vue";
---

<section class="relative bg-[#050d1e] py-24 overflow-hidden">

  <!-- Subtle top glow -->
  <div
    class="pointer-events-none absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
  ></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="flex flex-col gap-5 mb-14">
      <div class="flex items-center gap-3">
        <div class="h-px w-8 bg-[rgb(252,176,64)]"></div>
        <span class="text-[rgb(252,176,64)] text-[11px] font-semibold uppercase tracking-[0.28em]">
          Unsere Lösungen
        </span>
      </div>

      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <h2
          class="text-[2rem] lg:text-[2.5rem] font-bold leading-[1.1] tracking-[-0.02em] text-white max-w-[480px]"
        >
          Alles, was moderner<br />
          <span class="text-[rgb(252,176,64)]">Kundenkontakt braucht</span>
        </h2>
        <p class="text-[14px] text-white/35 leading-relaxed max-w-[340px] lg:text-right">
          Wählen Sie die Lösungsgruppe, die zu Ihrer Infrastruktur passt —
          von der KI-Schnittstelle bis zum fertigen Contact-Center.
        </p>
      </div>
    </div>

    <!-- Interactive tabs + cards (Vue island) -->
    <SolutionsTabs client:visible />

  </div>
</section>
