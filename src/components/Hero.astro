---
import HeroWave from "./HeroWave.vue";
import CustomerLogos from "./CustomerLogos.astro";
---

<style>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap");

  .h-wrap {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: #fff;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding-top: 3rem;
  }

  .h-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 1.5rem 0;
    gap: 1.6rem;
    position: relative;
    z-index: 2;
  }

  .h-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: #f4f4f5;
    border: 1px solid #e4e4e7;
    border-radius: 99px;
    padding: 0.32rem 0.9rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #71717a;
    opacity: 0;
    animation: upIn 0.7s 0.08s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .h-title {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2.6rem, 6.5vw, 4.5rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #09090b;
    font-weight: 800;
    margin: 0;
    opacity: 0;
    animation: upIn 0.82s 0.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* quieter top line so the blue word below carries the weight */
  .h-title-top {
    display: block;
    font-size: 0.52em;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #3f3f46;
    margin-bottom: 0.18em;
  }

  /* keyword carries a soft blue glow */
  .h-title-main {
    color: #1d4ed8;
    text-shadow:
      0 0 12px rgba(37, 99, 235, 0.18),
      0 0 26px rgba(29, 78, 216, 0.09);
  }

  .h-sub {
    max-width: 410px;
    font-size: 1rem;
    line-height: 1.7;
    color: #71717a;
    font-weight: 400;
    margin: 0;
    opacity: 0;
    animation: upIn 0.82s 0.34s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .h-cta {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #09090b;
    color: #fff;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: 99px;
    text-decoration: none;
    letter-spacing: 0.005em;
    opacity: 0;
    animation: upIn 0.82s 0.46s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transition:
      background 0.25s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease;
  }
  /* light sheen sweeping across on hover */
  .h-cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.16) 50%,
      transparent 70%
    );
    transform: translateX(-130%);
  }
  .h-cta:hover {
    background: #18181b;
    transform: translateY(-2px) scale(1.03);
    box-shadow:
      0 10px 32px rgba(29, 78, 216, 0.35),
      0 4px 12px rgba(9, 9, 11, 0.25);
  }
  .h-cta:hover::after {
    transition: transform 0.6s ease;
    transform: translateX(130%);
  }
  .h-cta:active {
    transform: translateY(0) scale(0.98);
  }

  /* mini voice waveform — frozen at rest, speaking on hover */
  .h-cta-eq {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    height: 16px;
  }
  .h-cta-eq i {
    display: block;
    width: 3px;
    border-radius: 2px;
    background: currentColor;
    transition: height 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .h-cta-eq i:nth-child(1) { height: 35%; }
  .h-cta-eq i:nth-child(2) { height: 75%; }
  .h-cta-eq i:nth-child(3) { height: 100%; }
  .h-cta-eq i:nth-child(4) { height: 55%; }

  .h-cta:hover .h-cta-eq i {
    animation: eqSpeak 0.8s ease-in-out infinite;
  }
  .h-cta:hover .h-cta-eq i:nth-child(2) {
    animation-duration: 0.65s;
    animation-delay: -0.15s;
  }
  .h-cta:hover .h-cta-eq i:nth-child(3) {
    animation-duration: 0.9s;
    animation-delay: -0.3s;
  }
  .h-cta:hover .h-cta-eq i:nth-child(4) {
    animation-duration: 0.7s;
    animation-delay: -0.45s;
  }

  @keyframes eqSpeak {
    0%, 100% { height: 25%; }
    50% { height: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .h-cta:hover .h-cta-eq i {
      animation: none;
    }
    .h-cta:hover::after {
      transition: none;
      transform: translateX(-130%);
    }
  }

  .h-waves {
    position: relative;
    width: 100%;
    height: clamp(280px, 44vh, 520px);
    margin-top: -5rem;
    flex-shrink: 0;
  }

  /* customer logos float over the lower wave area, like the reference */
  .h-logos {
    position: absolute;
    left: 0;
    right: 0;
    bottom: clamp(0.5rem, 4vh, 2rem);
    z-index: 2;
    opacity: 0;
    animation: upIn 0.82s 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes upIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<section class="h-wrap">
  <div class="h-content">
    <div class="h-badge">
      <svg
        class="h-badge-mic"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <defs>
          <!-- bottom-anchored fill level, bouncing like a voice meter -->
          <clipPath id="h-mic-fill">
            <rect x="6" width="12" height="20">
              <animate
                attributeName="y"
                values="13.5;5;10;3;11.5;6;12.5;4;9;13.5"
                dur="2.2s"
                repeatCount="indefinite"></animate>
            </rect>
          </clipPath>
        </defs>
        <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"></path>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
        <line x1="12" y1="19" x2="12" y2="23"></line>
        <line x1="8" y1="23" x2="16" y2="23"></line>
        <path
          d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"
          fill="#2563eb"
          stroke="none"
          clip-path="url(#h-mic-fill)"></path>
      </svg>
      AI-Powered Voice Solutions
    </div>

    <h1 class="h-title">
      <span class="h-title-top">Die Zukunft des</span>
      <span class="h-title-main">Kundenkontakts</span>
    </h1>

    <p class="h-sub">
      Intelligente Sprachlösungen, die Kundengespräche automatisieren —
      schneller, skalierbarer und natürlicher als je zuvor.
    </p>

    <a href="/kontakt" class="h-cta">
      <span class="h-cta-eq" aria-hidden="true">
        <i></i><i></i><i></i><i></i>
      </span>
      Jetzt starten
    </a>
  </div>

  <div class="h-waves">
    <HeroWave client:load />
    <div class="h-logos">
      <CustomerLogos />
    </div>
  </div>
</section>
