---
const industries = [
  {
    title: "Carrier & Telcos",
    eyebrow: "Carrier grade",
    image: "/industries/telecommunication_infrastructure_photo.png",
    desc: "Hochverfügbare Voice-Plattformen, SIP-Trunking und Echtzeit-Fraud-Schutz für Netze mit hoher Last.",
    href: "/telco-solutions/service-delivery-platform",
  },
  {
    title: "Behörden & Verwaltung",
    eyebrow: "Trust first",
    image: "/industries/photo_of_a_public_authority_building.png",
    desc: "On-Premise Voice-Bots mit sauberer Prozessintegration und DSGVO-konformer Auskunft.",
    href: "/about",
  },
  {
    title: "Banken & Versicherungen",
    eyebrow: "Compliance",
    image: "/industries/banking_operations_or_privat.png",
    desc: "Revisionssichere Aufzeichnung, Transkription und Analyse für regulierte Umgebungen.",
    href: "/about",
  },
  {
    title: "E-Mobilität",
    eyebrow: "Connected",
    image: "/industries/EV_charging_location_with_multiple_cars.png",
    desc: "Störungsannahme, Routing und Self-Service für skalierende Infrastruktur- und Service-Netze.",
    href: "/telco-solutions/service-delivery-platform",
  },
  {
    title: "Handel & Teleshopping",
    eyebrow: "High volume",
    image: "/industries/teleshopping_broadcast_studio.png",
    desc: "KI-Voice-Agents, die Spitzenlast abfangen, Bestellungen aufnehmen und Rückfragen lösen.",
    href: "/about",
  },
];
---

<section class="industries-section bg-[#f7f9fd] py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="mb-14 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <div class="section-eyebrow">
          <div class="section-eyebrow__line"></div>
          <span>Branchen</span>
        </div>
        <h2 class="section-title">
          Präzise für jede
          <span class="section-title__accent">Umgebung</span>
        </h2>
        <p class="section-sub">
          CreaLog verbindet Carrier-Qualität mit einer klaren, ruhigen Oberfläche - von öffentlichen Einrichtungen bis zu hochfrequenten Service-Szenarien.
        </p>
      </div>

      <a
        href="/about"
        class="section-link"
      >
        Mehr über CreaLog
        <span>↗</span>
      </a>
    </div>

    <div class="grid gap-5 lg:grid-cols-12">
      <article class="industry-feature reveal lg:col-span-5">
        <img
          src={industries[0].image}
          alt={industries[0].title}
          class="industry-feature__img"
          loading="lazy"
        />
        <div class="industry-feature__shade"></div>
        <div class="industry-feature__content">
          <div class="industry-chip">{industries[0].eyebrow}</div>
          <h3>{industries[0].title}</h3>
          <p>{industries[0].desc}</p>
          <a href={industries[0].href} class="industry-cta">
            Mehr erfahren
            <span>→</span>
          </a>
        </div>
      </article>

      <div class="grid gap-5 sm:grid-cols-2 lg:col-span-7">
        {industries.slice(1).map((industry, index) => (
          <article class="industry-card reveal" style={`transition-delay: ${index * 90}ms`}>
            <img
              src={industry.image}
              alt={industry.title}
              class="industry-card__img"
              loading="lazy"
            />
            <div class="industry-card__shade"></div>
            <div class="industry-card__content">
              <div class="industry-chip">{industry.eyebrow}</div>
              <h3>{industry.title}</h3>
              <p>{industry.desc}</p>
              <a href={industry.href} class="industry-cta">
                Mehr erfahren
                <span>→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .industries-section {
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1rem;
  }

  .section-eyebrow__line {
    width: 24px;
    height: 1px;
    background: #1d6bbf;
    flex-shrink: 0;
  }

  .section-eyebrow span {
    color: #1d6bbf;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.28em;
  }

  .section-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: #0a1628;
  }

  .section-title__accent {
    color: #1d6bbf;
  }

  .section-sub {
    margin: 1rem 0 0;
    max-width: 50rem;
    font-size: 15px;
    line-height: 1.7;
    color: #5b6472;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    color: #1d6bbf;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: gap 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .section-link:hover {
    gap: 0.7rem;
  }

  .industry-feature,
  .industry-card {
    position: relative;
    overflow: hidden;
    border-radius: 1.75rem;
    min-height: 16rem;
    background: #0a1628;
    border: 1px solid rgba(29, 107, 191, 0.12);
    box-shadow: 0 20px 60px rgba(10, 22, 40, 0.08);
  }

  .industry-feature {
    min-height: 34rem;
  }

  .industry-feature__img,
  .industry-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .industry-feature__shade,
  .industry-card__shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(7, 16, 29, 0.12) 0%, rgba(7, 16, 29, 0.45) 65%, rgba(7, 16, 29, 0.88) 100%),
      linear-gradient(90deg, rgba(29, 107, 191, 0.12) 0%, transparent 35%, transparent 100%);
  }

  .industry-feature__content,
  .industry-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    padding: 1.5rem;
    color: #fff;
  }

  .industry-feature__content {
    padding: 2rem;
  }

  .industry-feature__content h3,
  .industry-card__content h3 {
    margin: 0.9rem 0 0;
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .industry-card__content h3 {
    font-size: 1.1rem;
  }

  .industry-feature__content p,
  .industry-card__content p {
    margin: 0.75rem 0 0;
    max-width: 28ch;
    font-size: 13.5px;
    line-height: 1.65;
    color: rgba(219, 234, 254, 0.72);
  }

  .industry-chip {
    width: fit-content;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.84);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .industry-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    margin-top: 1.25rem;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: gap 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .industry-cta:hover {
    gap: 0.7rem;
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .section-link,
    .industry-cta {
      transition: none;
    }

    .section-link:hover,
    .industry-cta:hover {
      gap: 0.5rem;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>(".industries-section");
  if (section) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const els = section.querySelectorAll<HTMLElement>(".reveal");

    if (reduce) {
      els.forEach((el) => el.classList.add("is-visible"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 },
      );

      els.forEach((el) => io.observe(el));
    }
  }
</script>
