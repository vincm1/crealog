---
// Newsletter-Sektion — bettet das von Brevo gehostete Anmeldeformular
// (sibforms iframe) ein. Brevo übernimmt Validierung, Double-Opt-In,
// Listenzuordnung und DSGVO-Bestätigung serverseitig — daher kein API-Key
// und kein eigener Endpoint nötig; funktioniert mit `output: "static"`.
//
// Höhe: Das Brevo-Formular ist cross-origin und sendet KEINE Höhen-postMessage,
// daher lässt sich der iframe nicht automatisch an seinen Inhalt anpassen. Die
// reale Formularhöhe hängt von der Breite ab (schmaler = mehr Umbruch = höher);
// gemessen ~922px @540px … ~1300px @300px. Wir setzen deshalb feste, groß genug
// gewählte Höhen pro Breakpoint, damit das GESAMTE Formular (inkl. Button)
// sichtbar bleibt statt intern zu scrollen.
interface Props {
  title?: string;
  subline?: string;
  /** Vollständige sibforms-Embed-URL aus dem Brevo-Formular-Editor. */
  formSrc?: string;
}

const {
  title = "Bleiben Sie auf dem Laufenden",
  subline = "Melden Sie sich für unseren Newsletter an und erhalten Sie Neuigkeiten zu KI-gestützten Sprachlösungen direkt in Ihr Postfach.",
  formSrc = "https://35f86a8e.sibforms.com/v2/serve/MUIFAHiU2vugQOnFJ5PKwTP_3nzdxJ-LfNgtCmKJQtDfPaRVCIuu7mt51I7X5MldllKTFXf0fkuRo6t0GOfR3fAmJI2z-6sPmPeESxHXVm0TMUw5LSNX_tTEGjY8rEp_FuNy16NcwTY2JOV31HuwgbVGDAX7xlGQeqE7aFX3NXdZjcX7JGEQJU5b2AYFOZCY4XyKbp_D4loG6Oxbmg==",
} = Astro.props;
---

<section class="nl-section">
  <div class="nl-inner">
    <div class="nl-copy">
      <span class="nl-eyebrow">Newsletter</span>
      <h2 class="nl-title">{title}</h2>
      <p class="nl-sub">{subline}</p>
    </div>

    <div class="nl-form">
      <iframe
        class="nl-iframe"
        src={formSrc}
        width="540"
        height="940"
        frameborder="0"
        scrolling="auto"
        allowfullscreen
        loading="lazy"
        title="Newsletter-Anmeldung"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .nl-section {
    font-family: "Poppins", Calibri, sans-serif;
    background: #f1f5fb;
    border-top: 1px solid #dce5f0;
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .nl-inner {
    max-width: 80rem; /* max-w-7xl */
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .nl-inner {
      grid-template-columns: 1fr auto;
      padding: 0 2.5rem;
      gap: 4rem;
    }
  }

  .nl-copy {
    max-width: 32rem;
  }

  .nl-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(0 64 129);
    margin-bottom: 0.9rem;
  }

  .nl-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #0f1e30;
    margin: 0;
  }

  .nl-sub {
    margin: 1rem 0 0;
    font-size: 1rem;
    line-height: 1.7;
    color: #4b5563;
  }

  .nl-form {
    width: 100%;
  }

  /* Voller iframe — Höhe pro Breakpoint so gewählt, dass das komplette
     Brevo-Formular sichtbar bleibt (keine interne Scroll-Klippe mehr). */
  .nl-iframe {
    display: block;
    width: 540px;
    max-width: 100%;
    height: 940px;
    margin: 0 auto;
    border: 0;
  }

  @media (max-width: 600px) {
    .nl-iframe {
      height: 1060px;
    }
  }
  @media (max-width: 480px) {
    .nl-iframe {
      height: 1200px;
    }
  }
  @media (max-width: 380px) {
    .nl-iframe {
      height: 1320px;
    }
  }
</style>
