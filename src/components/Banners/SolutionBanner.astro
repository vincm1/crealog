---
// Slim full-bleed banner — light-blue gradient background (same color language as
// ProductHero's hero-glow). A short message line plus customer logos placed directly
// on the gradient (transparent, no cards). Used on solution sub-pages.
interface Logo {
  name: string;
  src?: string;
  width?: number;
  height?: number;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  subline?: string;
  logos?: Logo[];
}

const {
  subline = "Von Telekommunikationskonzernen bis zum Mittelstand – CreaLog Voice Bots beantworten täglich Anrufe in über 100 Sprachen, rund um die Uhr.",
  logos = [
    { name: "Deutsche Telekom", src: "/customer_logos/telekom_logo.png",  width: 130, height: 40 },
    { name: "Swisscom",         src: "/customer_logos/swisscom_logo.png", width: 120, height: 36 },
    { name: "A1 Telekom",       src: "/customer_logos/a1_logo.jpg",       width: 60,  height: 36 },
    { name: "Sky",              src: "/customer_logos/sky_logo.png",      width: 80,  height: 36 },
  ],
} = Astro.props;
---

<section class="sb-section">
  <!-- Decorative layers -->
  <div class="sb-glow" aria-hidden="true"></div>
  <div class="sb-grid" aria-hidden="true"></div>

  <div class="sb-inner">
    {subline && <p class="sb-subline">{subline}</p>}

    {logos.length > 0 && (
      <div class="sb-logos" aria-label="Kundenreferenzen">
        {logos.map((logo) => (
          logo.src ? (
            <img
              src={logo.src}
              alt={logo.name}
              title={logo.name}
              width={logo.width ?? 120}
              height={logo.height ?? 36}
              class="sb-logo-img"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="sb-logo-text" title={logo.name}>{logo.name}</span>
          )
        ))}
      </div>
    )}
  </div>
</section>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap");

  .sb-section {
    font-family: "Plus Jakarta Sans", sans-serif;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 6vw, 4rem);
    /* Full light-blue gradient background — the "colored band" */
    background:
      radial-gradient(ellipse 70% 70% at 50% -20%, rgba(56, 168, 255, 0.26), transparent 62%),
      linear-gradient(180deg, #eef5fe 0%, #ddecfc 52%, #cfe4fb 100%);
  }

  /* Soft royalblau glow blob, anchored low-center (same recipe as hero-glow) */
  .sb-glow {
    position: absolute;
    left: 50%;
    bottom: -55%;
    transform: translateX(-50%);
    width: min(1100px, 110%);
    height: 320px;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      ellipse 50% 50% at 50% 50%,
      rgba(37, 99, 235, 0.22) 0%,
      rgba(0, 73, 144, 0.12) 38%,
      rgba(56, 168, 255, 0.06) 60%,
      transparent 78%
    );
    filter: blur(48px);
  }

  /* Faint dotted grid for depth */
  .sb-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(0, 73, 144, 0.08) 1px, transparent 1px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(ellipse 80% 75% at 50% 50%, black 0%, transparent 78%);
    mask-image: radial-gradient(ellipse 80% 75% at 50% 50%, black 0%, transparent 78%);
  }

  .sb-inner {
    position: relative;
    z-index: 1;
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .sb-subline {
    margin: 0;
    font-size: clamp(0.95rem, 1.3vw, 1.0625rem);
    line-height: 1.7;
    font-weight: 500;
    color: #3f5469;
    max-width: 60ch;
    animation: sb-appear 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── Logo strip — transparent, placed directly on the gradient ── */
  .sb-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(1.75rem, 4vw, 3.25rem);
    margin-top: clamp(1.75rem, 3.5vw, 2.5rem);
    animation: sb-appear 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.12s both;
  }

  .sb-logo-img {
    max-width: 130px;
    max-height: 40px;
    width: auto;
    height: auto;
    object-fit: contain;
    /* Monochrom: entfärben + weiße Logo-Hintergründe in den Verlauf einschmelzen */
    filter: grayscale(1);
    opacity: 0.7;
    mix-blend-mode: multiply;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .sb-logo-img:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  .sb-logo-text {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #5b7790;
    text-align: center;
  }

  @keyframes sb-appear {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .sb-logo-img {
      max-width: 100px;
      max-height: 32px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sb-subline,
    .sb-logos {
      animation: none;
    }
    .sb-logo-img { transition: none; }
    .sb-logo-img:hover { transform: none; }
  }
</style>
