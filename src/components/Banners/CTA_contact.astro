---
interface Props {
  eyebrow?: string;
  headline?: string;
  subline?: string;
  href?: string;
  hrefSecondary?: string;
}

const {
  eyebrow = "Kontakt",
  headline = "Sprechen Sie mit uns. Wir hören zu.",
  subline = "Ob KI-Voicebot, Carrier-Infrastruktur oder Beratung — unsere Experten finden mit Ihnen die passende Lösung.",
  href = "/demo",
  hrefSecondary = "/kontakt",
} = Astro.props;
---

<div class="cta-contact">
  <div class="cta-aurora" aria-hidden="true"></div>
  <div class="cta-grid" aria-hidden="true"></div>

  <div class="cta-body">
    <span class="cta-eyebrow">{eyebrow}</span>
    <h2 class="cta-headline">{headline}</h2>
    <p class="cta-subline">{subline}</p>
  </div>

  <div class="cta-actions">
    <a href={href} class="cta-primary">
      Demo anfragen
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"></path>
        <path d="M12 5l7 7-7 7"></path>
      </svg>
    </a>
    <a href={hrefSecondary} class="cta-secondary">Kontakt aufnehmen</a>
  </div>
</div>

<style>
  .cta-contact {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(2rem, 5vw, 4rem);
    border-radius: 24px;
    padding: clamp(2.5rem, 5vw, 3.75rem) clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(180deg, #0b1729 0%, #060d1a 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  /* animated aurora — slow drifting brand-coloured blobs */
  .cta-aurora {
    position: absolute;
    inset: -40%;
    z-index: -2;
    background:
      radial-gradient(40% 50% at 20% 30%, rgba(56, 189, 248, 0.30), transparent 60%),
      radial-gradient(35% 45% at 80% 70%, rgba(29, 78, 216, 0.40), transparent 60%),
      radial-gradient(30% 40% at 60% 20%, rgba(99, 102, 241, 0.28), transparent 60%);
    filter: blur(20px);
    animation: ctaDrift 18s ease-in-out infinite alternate;
  }
  @keyframes ctaDrift {
    0% {
      transform: translate3d(-4%, -2%, 0) scale(1);
    }
    50% {
      transform: translate3d(3%, 4%, 0) scale(1.12);
    }
    100% {
      transform: translate3d(5%, -3%, 0) scale(1.05);
    }
  }

  /* fine dot grid overlay */
  .cta-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.10) 1px,
      transparent 1px
    );
    background-size: 26px 26px;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 30%, #000 100%);
    mask-image: linear-gradient(90deg, transparent, #000 30%, #000 100%);
    pointer-events: none;
  }

  .cta-body {
    position: relative;
    max-width: 30rem;
  }

  .cta-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #7dd3fc;
    margin-bottom: 0.9rem;
  }

  .cta-headline {
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0;
    background: linear-gradient(180deg, #ffffff 0%, #cdd9ec 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .cta-subline {
    margin: 1rem 0 0;
    font-size: 14.5px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    max-width: 28rem;
  }

  .cta-actions {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-shrink: 0;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    color: #0a1628;
    font-size: 14px;
    font-weight: 700;
    padding: 0.8rem 1.6rem;
    border-radius: 9999px;
    text-decoration: none;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1), 0 8px 24px rgba(56, 189, 248, 0.18);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease;
  }
  .cta-primary svg {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.2), 0 14px 34px rgba(56, 189, 248, 0.35);
  }
  .cta-primary:hover svg {
    transform: translateX(3px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    padding: 0.8rem 1.6rem;
    border-radius: 9999px;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.35);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .cta-contact {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }
    .cta-body {
      max-width: 100%;
    }
    .cta-actions {
      width: 100%;
    }
    .cta-primary,
    .cta-secondary {
      flex: 1;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-aurora {
      animation: none;
    }
  }
</style>
