---
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  headline?: string;
  subline?: string;
  href?: string;
  hrefSecondary?: string;
  image?: string;
  imageAlt?: string;
  topicIcon?: string;
}

const {
  eyebrow = "Kontakt",
  headline = "Sprechen Sie mit uns. Wir hören zu.",
  subline = "Ob KI-Voicebot, Carrier-Infrastruktur oder Beratung — unsere Experten finden mit Ihnen die passende Lösung.",
  href = "/demo",
  hrefSecondary = "/kontakt",
  image,
  imageAlt = "Experte",
  topicIcon = "heroicons:chat-bubble-left-ellipsis",
} = Astro.props;
---

<div class="cta-contact">
  <div class="cta-aurora" aria-hidden="true"></div>
  <div class="cta-grid" aria-hidden="true"></div>

  <div class="cta-left">
    <div class="cta-body">
      <span class="cta-eyebrow">{eyebrow}</span>
      <h2 class="cta-headline">{headline}</h2>
      <p class="cta-subline">{subline}</p>
    </div>

    <div class="cta-actions">
      <a href={href} class="cta-primary">
        Demo anfragen
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="M12 5l7 7-7 7"></path>
        </svg>
      </a>
      <a href={hrefSecondary} class="cta-secondary">Kontakt aufnehmen</a>
    </div>
  </div>

  <div class="cta-visual" aria-hidden="true">
    {image ? (
      <img src={image} alt={imageAlt} class="cta-expert-photo" />
    ) : (
      <div class="cta-avatar-wrap">
        <div class="cta-avatar">
          <svg viewBox="0 0 80 90" fill="none" xmlns="http://www.w3.org/2000/svg" class="cta-avatar-svg" aria-hidden="true">
            <circle cx="40" cy="28" r="18" fill="rgba(255,255,255,0.80)" />
            <ellipse cx="40" cy="78" rx="28" ry="20" fill="rgba(255,255,255,0.80)" />
          </svg>
        </div>
        <div class="cta-topic-badge">
          <Icon name={topicIcon} class="cta-topic-icon" />
        </div>
      </div>
    )}
  </div>
</div>

<style>
  .cta-contact {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(2rem, 5vw, 4rem);
    border-radius: 24px;
    padding: clamp(2.5rem, 5vw, 3.75rem) clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(180deg, #0b1729 0%, #060d1a 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  /* animated aurora — slow drifting brand-coloured blobs */
  .cta-aurora {
    position: absolute;
    inset: -40%;
    z-index: -2;
    background:
      radial-gradient(40% 50% at 20% 30%, rgba(56, 189, 248, 0.30), transparent 60%),
      radial-gradient(35% 45% at 80% 70%, rgba(29, 78, 216, 0.40), transparent 60%),
      radial-gradient(30% 40% at 60% 20%, rgba(99, 102, 241, 0.28), transparent 60%);
    filter: blur(20px);
    animation: ctaDrift 18s ease-in-out infinite alternate;
  }
  @keyframes ctaDrift {
    0% {
      transform: translate3d(-4%, -2%, 0) scale(1);
    }
    50% {
      transform: translate3d(3%, 4%, 0) scale(1.12);
    }
    100% {
      transform: translate3d(5%, -3%, 0) scale(1.05);
    }
  }

  /* fine dot grid overlay */
  .cta-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.10) 1px,
      transparent 1px
    );
    background-size: 26px 26px;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 30%, #000 100%);
    mask-image: linear-gradient(90deg, transparent, #000 30%, #000 100%);
    pointer-events: none;
  }

  /* left column: text + buttons stacked */
  .cta-left {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    flex: 1;
    min-width: 0;
  }

  .cta-body {
    max-width: 30rem;
  }

  .cta-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #7dd3fc;
    margin-bottom: 0.9rem;
  }

  .cta-headline {
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0;
    background: linear-gradient(180deg, #ffffff 0%, #cdd9ec 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .cta-subline {
    margin: 1rem 0 0;
    font-size: 14.5px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    max-width: 28rem;
  }

  .cta-actions {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    color: #0a1628;
    font-size: 14px;
    font-weight: 700;
    padding: 0.8rem 1.6rem;
    border-radius: 9999px;
    text-decoration: none;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1), 0 8px 24px rgba(56, 189, 248, 0.18);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease;
  }
  .cta-primary svg {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.2), 0 14px 34px rgba(56, 189, 248, 0.35);
  }
  .cta-primary:hover svg {
    transform: translateX(3px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    padding: 0.8rem 1.6rem;
    border-radius: 9999px;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.35);
    transform: translateY(-2px);
  }

  /* right column: visual */
  .cta-visual {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* avatar placeholder */
  .cta-avatar-wrap {
    position: relative;
    width: 136px;
    height: 136px;
  }

  .cta-avatar {
    width: 136px;
    height: 136px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1.5px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      0 0 48px rgba(56, 189, 248, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    backdrop-filter: blur(10px);
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .cta-avatar:hover {
    transform: scale(1.05);
    box-shadow:
      0 0 64px rgba(56, 189, 248, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .cta-avatar-svg {
    width: 88%;
    height: 88%;
    opacity: 0.72;
  }

  /* topic icon badge */
  .cta-topic-badge {
    position: absolute;
    bottom: 2px;
    right: -2px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(6, 13, 26, 0.88);
    border: 1.5px solid rgba(125, 211, 252, 0.35);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(56, 189, 248, 0.22);
  }

  .cta-topic-icon {
    width: 18px;
    height: 18px;
    color: #7dd3fc;
  }

  /* real expert photo */
  .cta-expert-photo {
    width: 136px;
    height: 136px;
    border-radius: 50%;
    object-fit: cover;
    border: 1.5px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 0 48px rgba(56, 189, 248, 0.16);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-expert-photo:hover {
    transform: scale(1.05);
  }

  @media (max-width: 860px) {
    .cta-contact {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }
    .cta-body {
      max-width: 100%;
    }
    .cta-left {
      width: 100%;
      gap: 1.5rem;
    }
    .cta-actions {
      width: 100%;
    }
    .cta-primary,
    .cta-secondary {
      flex: 1;
      justify-content: center;
    }
    .cta-visual {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-aurora {
      animation: none;
    }
    .cta-avatar,
    .cta-expert-photo {
      transition: none;
    }
    .cta-avatar:hover,
    .cta-expert-photo:hover {
      transform: none;
    }
  }
</style>
