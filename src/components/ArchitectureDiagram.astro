---
const channels = ['IMS', 'SMS / RCS', 'Web / APP', 'Messenger', 'MS Teams'] as const;
---

<div class="max-w-2xl mx-auto px-4 py-10 select-none">

  <!-- ── SCE outer container ── -->
  <div class="rounded-3xl border-2 border-amber-400 bg-amber-50/30 p-6 shadow-sm">

    <p class="text-center text-[10.5px] font-bold text-[#004990] mb-5 uppercase tracking-[0.18em]">
      CreaLog Service Creation Environment (SCE)
    </p>

    <!-- Row 1: sources -->
    <div class="grid grid-cols-2 gap-4">
      <div class="rounded-2xl border-2 border-amber-400 bg-white px-4 py-4 text-center shadow-sm">
        <p class="text-[12.5px] font-semibold text-[#004990] leading-snug">
          MCP Server / Database / CRM / Backend
        </p>
      </div>
      <div class="rounded-2xl border-2 border-amber-400 bg-white px-4 py-4 text-center shadow-sm">
        <p class="text-[12.5px] font-semibold text-[#004990] leading-snug">
          AI Services Components
        </p>
        <p class="text-[10.5px] text-gray-400 mt-1">(LLMs, Conversational AI, …)</p>
      </div>
    </div>

    <!-- Crossing arrows -->
    <div class="relative h-14">
      <svg
        class="absolute inset-0 w-full h-full"
        viewBox="0 0 200 56"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <marker id="sce-ah" markerWidth="8" markerHeight="6" refX="6" refY="3" orient="auto">
            <polygon points="0 0, 8 3, 0 6" fill="#f59e0b" />
          </marker>
        </defs>
        <!-- straight: left→left, right→right -->
        <line x1="50"  y1="3" x2="50"  y2="51" stroke="#f59e0b" stroke-width="2" marker-end="url(#sce-ah)" />
        <line x1="150" y1="3" x2="150" y2="51" stroke="#f59e0b" stroke-width="2" marker-end="url(#sce-ah)" />
        <!-- cross: left→right, right→left -->
        <line x1="50"  y1="3" x2="150" y2="51" stroke="#f59e0b" stroke-width="2" marker-end="url(#sce-ah)" />
        <line x1="150" y1="3" x2="50"  y2="51" stroke="#f59e0b" stroke-width="2" marker-end="url(#sce-ah)" />
      </svg>
    </div>

    <!-- Row 2: outputs -->
    <div class="grid grid-cols-2 gap-4">
      <div class="rounded-2xl border-2 border-amber-400 bg-white px-4 py-4 text-center shadow-sm">
        <p class="text-[12.5px] font-semibold text-[#004990]">Standard Applications & Bots</p>
      </div>
      <div class="rounded-2xl border-2 border-amber-400 bg-white px-4 py-4 text-center shadow-sm">
        <p class="text-[12.5px] font-semibold text-[#004990]">Custom Applications & Bots</p>
      </div>
    </div>
  </div>

  <!-- Two arrows: bottom row → SDP (aligned to column centers ≈ 25% / 75%) -->
  <div class="relative h-10">
    <svg
      class="absolute inset-0 w-full h-full"
      viewBox="0 0 200 40"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <marker id="sdp-ah" markerWidth="8" markerHeight="6" refX="6" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="#f59e0b" />
        </marker>
      </defs>
      <line x1="50"  y1="0" x2="50"  y2="36" stroke="#f59e0b" stroke-width="2" marker-end="url(#sdp-ah)" />
      <line x1="150" y1="0" x2="150" y2="36" stroke="#f59e0b" stroke-width="2" marker-end="url(#sdp-ah)" />
    </svg>
  </div>

  <!-- ── SDP box ── -->
  <div class="rounded-3xl border-2 border-amber-400 bg-amber-50/30 px-6 py-4 text-center shadow-sm">
    <p class="text-[10.5px] font-bold text-[#004990] uppercase tracking-[0.18em]">
      CreaLog Service Delivery Platform (SDP)
    </p>
  </div>

  <!-- Single arrow: SDP → channels -->
  <div class="flex justify-center">
    <svg width="14" height="36" viewBox="0 0 14 36" xmlns="http://www.w3.org/2000/svg">
      <line x1="7" y1="0" x2="7" y2="28" stroke="#f59e0b" stroke-width="2" />
      <polygon points="1,24 13,24 7,34" fill="#f59e0b" />
    </svg>
  </div>

  <!-- ── Channel cloud icons ── -->
  <div class="grid grid-cols-5 gap-2 mt-1">
    {channels.map(ch => (
      <div class="flex flex-col items-center gap-2">
        <svg
          class="w-14 h-10 text-[#004990]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"
          />
        </svg>
        <span class="text-[10.5px] font-semibold text-[#004990] text-center leading-tight">{ch}</span>
      </div>
    ))}
  </div>
</div>
