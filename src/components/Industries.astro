---
const industries = [
  {
    title: "Carrier & Telcos",
    img: "/industries/telecommunication_infrastructure_photo.png",
    headline: "Sprachdienste in Carrier-Qualität",
    desc: "Hochverfügbare Voice-Plattformen, SIP-Trunking und Echtzeit-Fraud-Schutz — skalierbar bis in den Millionen-Anruf-Bereich.",
  },
  {
    title: "Behörden & Verwaltung",
    img: "/industries/photo_of_a_public_authority_building.png",
    headline: "Bürgerservice rund um die Uhr",
    desc: "On-Premise Voice-Bots, die sich in bestehende Fachverfahren integrieren und Anfragen DSGVO-konform automatisiert beantworten.",
  },
  {
    title: "Banken & Versicherungen",
    img: "/industries/banking_operations_or_privat.png",
    headline: "Compliance-sichere Sprachprozesse",
    desc: "Revisionssichere Aufzeichnung, Transkription und Analyse — MaRisk- und DSGVO-konform, on-premise oder hybrid.",
  },
  {
    title: "Netzbetreiber",
    img: "/industries/EV_charging_location_with_multiple_cars.png",
    headline: "Netzqualität, die man hört",
    desc: "Intelligentes Call-Routing, Kapazitätsmonitoring und automatisierte Störungsannahme für stabile Sprachnetze.",
  },
  {
    title: "Handel & Teleshopping",
    img: "/industries/teleshopping_broadcast_studio.png",
    headline: "Bestellannahme ohne Warteschleife",
    desc: "KI-Voice-Agents nehmen Bestellungen rund um die Uhr entgegen, beantworten Rückfragen und entlasten Spitzenlasten.",
  },
];
---

<section class="ind-section">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Header -->
    <div class="ind-head reveal">
      <span class="ind-eyebrow">Branchen</span>
      <h2 class="ind-title">Jede Branche.<br />Jeder Kontaktpunkt.</h2>
      <p class="ind-sub">
        CreaLog automatisiert Kundengespräche end-to-end — von der
        Carrier-Infrastruktur bis zum Bürgerservice.
      </p>
    </div>

    <!-- Controls -->
    <div class="ind-controls reveal">
      <button type="button" class="ind-arrow" data-dir="-1" aria-label="Zurück">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"></path><path d="M12 19l-7-7 7-7"></path>
        </svg>
      </button>
      <div class="ind-dots">
        {industries.map((_, i) => <button type="button" class:list={["ind-dot", i === 0 && "is-active"]} aria-label={`Branche ${i + 1}`} />)}
      </div>
      <button type="button" class="ind-arrow" data-dir="1" aria-label="Weiter">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>

    <!-- Tile row -->
    <div class="ind-scroll">
      <div class="ind-row">
        {
          industries.map((it, i) => (
            <div class:list={["ind-item", i === 0 && "is-active"]} data-i={i}>
              <button type="button" class="ind-tile" aria-label={it.title}>
                {it.img ? (
                  <img src={it.img} alt={it.title} loading="lazy" />
                ) : (
                  <span class="ind-ph" />
                )}
                <span class="ind-tile-title">{it.title}</span>
              </button>
              <div class="ind-caption">
                <h3 class="ind-cap-head">{it.headline}</h3>
                <p class="ind-cap-desc">{it.desc}</p>
                <a href="#" class="ind-cap-link">
                  Mehr erfahren
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .ind-section {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: #fff;
    padding: 6rem 0;
  }

  /* header */
  .ind-head {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .ind-eyebrow {
    display: inline-block;
    color: #1d4ed8;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    margin-bottom: 1rem;
  }
  .ind-title {
    font-size: clamp(2rem, 4vw, 2.9rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: #09090b;
    margin: 0;
  }
  .ind-sub {
    margin: 1.1rem auto 0;
    max-width: 460px;
    font-size: 16px;
    line-height: 1.7;
    color: #5b6472;
  }

  /* controls */
  .ind-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 760px;
    margin: 2.5rem auto 2.5rem;
  }
  .ind-arrow {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid #e4e4e7;
    background: #fff;
    color: #3f3f46;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }
  .ind-arrow:hover {
    border-color: #09090b;
    color: #09090b;
    transform: translateY(-1px);
  }
  .ind-dots {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .ind-dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    border: none;
    background: #d4d4d8;
    cursor: pointer;
    padding: 0;
    transition:
      width 0.3s ease,
      background 0.2s ease;
  }
  .ind-dot.is-active {
    width: 24px;
    background: #09090b;
  }

  /* tile row */
  .ind-scroll {
    overflow-x: auto;
    scrollbar-width: none;
    /* breathing room so the drop shadows aren't clipped */
    padding: 8px 16px 32px;
  }
  .ind-scroll::-webkit-scrollbar {
    display: none;
  }
  .ind-row {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    width: max-content;
    margin: 0 auto;
  }

  .ind-item {
    flex: none;
    width: 200px;
    transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ind-item.is-active {
    width: 360px;
  }
  .ind-tile {
    position: relative;
    display: block;
    width: 100%;
    height: 250px;
    border-radius: 6px;
    overflow: hidden;
    border: none;
    padding: 0;
    cursor: pointer;
    background: #eef1f6;
    /* one-sided soft shadow to the right & bottom (negative spread keeps it off
       the top/left edges) */
    box-shadow: 8px 11px 22px -8px rgba(15, 23, 42, 0.2);
    transition:
      height 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.5s ease;
  }
  .ind-item.is-active .ind-tile {
    height: 460px;
    cursor: default;
    box-shadow: 14px 20px 40px -12px rgba(15, 23, 42, 0.26);
  }
  .ind-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* placeholder for industries without a photo yet */
  .ind-ph {
    display: block;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(160deg, #33415c 0%, #1e2738 100%);
  }
  .ind-ph::after {
    content: "Bild folgt";
    position: absolute;
    bottom: 0.9rem;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }
  /* legibility gradient for the title */
  .ind-tile::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 90px;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.45), transparent);
    pointer-events: none;
  }
  .ind-tile-title {
    position: absolute;
    top: 0.85rem;
    left: 0.95rem;
    right: 0.95rem;
    z-index: 1;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-align: left;
  }

  /* caption appears only under the active tile */
  .ind-caption {
    width: 100%;
    margin-top: 1.1rem;
    opacity: 0;
    height: 0;
    overflow: hidden;
    transition: opacity 0.4s ease 0.1s;
  }
  .ind-item.is-active .ind-caption {
    opacity: 1;
    height: auto;
  }
  .ind-cap-head {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: #09090b;
    letter-spacing: -0.01em;
  }
  .ind-cap-desc {
    margin: 0.5rem 0 0;
    font-size: 13.5px;
    line-height: 1.65;
    color: #6b7280;
  }
  .ind-cap-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.9rem;
    color: #004990;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: gap 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ind-cap-link:hover {
    gap: 0.7rem;
  }

  /* scroll reveal */
  .ind-section.reveal-ready .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ind-section.reveal-ready .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .ind-section.reveal-ready .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .ind-tile,
    .ind-caption {
      transition: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>(".ind-section");
  if (section) {
    const items = Array.from(section.querySelectorAll<HTMLElement>(".ind-item"));
    const dots = Array.from(section.querySelectorAll<HTMLElement>(".ind-dot"));
    const arrows = Array.from(section.querySelectorAll<HTMLElement>(".ind-arrow"));
    let active = 0;

    const show = (i: number) => {
      active = (i + items.length) % items.length;
      items.forEach((it, idx) => it.classList.toggle("is-active", idx === active));
      dots.forEach((d, idx) => d.classList.toggle("is-active", idx === active));
      items[active].scrollIntoView({
        block: "nearest",
        inline: "center",
        behavior: "smooth",
      });
    };

    items.forEach((it, i) =>
      it.querySelector(".ind-tile")?.addEventListener("click", () => show(i)),
    );
    dots.forEach((d, i) => d.addEventListener("click", () => show(i)));
    arrows.forEach((a) =>
      a.addEventListener("click", () =>
        show(active + Number(a.dataset.dir || "1")),
      ),
    );

    // reveal
    section.classList.add("reveal-ready");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    section.querySelectorAll<HTMLElement>(".reveal").forEach((el) => io.observe(el));
  }
</script>
