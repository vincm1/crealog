---
interface StatProp {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  bodyText?: string;
  ctaText?: string;
  ctaHref?: string;
  stats?: StatProp[];
}

const defaultStats: StatProp[] = [
  { value: "1993", label: "Gegründet" },
  { value: "100+", label: "Unternehmenskunden" },
  { value: "50+", label: "Mitarbeitende" },
];

function parseStat(s: StatProp) {
  const match = s.value.match(/^(\d+)(.*)$/);
  return {
    value: s.value,
    num: match ? parseInt(match[1]) : 0,
    suffix: match ? match[2] : "",
    label: s.label,
  };
}

const {
  eyebrow = "Über CreaLog",
  title = "Der verlässliche Partner für Sprachkommunikation",
  subtitle = "CreaLog entwickelt seit 1996 KI-gestützte Sprachlösungen für Telekommunikationsunternehmen und deren Enterprise-Kunden. Unsere Plattformen laufen in den Netzen führender Carrier Europas.",
  bodyText = "Unsere Lösungen laufen on-premise, in der Cloud oder hybrid — immer DSGVO-konform und made in Germany.",
  ctaText = "Mehr über CreaLog",
  ctaHref = "/about",
  stats: rawStats = defaultStats,
} = Astro.props;

const stats = rawStats.map(parseStat);
---

<section class="about-section bg-white py-24 lg:py-28 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center">
      <span class="reveal sec-eyebrow">{eyebrow}</span>
      <h2 class="reveal sec-title">{title}</h2>
      <p class="reveal sec-sub">{subtitle}</p>
    </div>

    <!-- Compact stats row -->
    <div class="reveal stats-row">
      {
        stats.map((s, i) => (
          <>
            <div class="stats-row__item">
              <span
                class="stats-row__num"
                data-num={s.num}
                data-suffix={s.suffix}
              >
                {s.value}
              </span>
              <span class="stats-row__label">{s.label}</span>
            </div>
            {i < stats.length - 1 && (
              <div class="stats-row__divider" aria-hidden="true" />
            )}
          </>
        ))
      }
    </div>

    <!-- Closing text + CTA -->
    <div class="max-w-2xl mx-auto mt-14 text-center">
      <p class="reveal text-[15px] leading-[1.75] text-[#5b6472]">{bodyText}</p>
      <div class="reveal mt-7">
        <a href={ctaHref} class="about-cta">
          {ctaText}
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14"></path>
            <path d="M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .sec-eyebrow {
    display: inline-block;
    color: #1d4ed8;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    margin-bottom: 1rem;
  }
  .sec-title {
    font-size: clamp(2rem, 4vw, 2.9rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #09090b;
    margin: 0;
  }
  .sec-sub {
    margin-top: 1.1rem;
    font-size: 16px;
    line-height: 1.7;
    color: #5b6472;
  }

  /* compact stats row */
  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: nowrap;
    gap: 0;
    margin: 3rem auto 3.5rem;
    max-width: 780px;
  }
  .stats-row__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem 2rem;
    text-align: center;
  }
  .stats-row__num {
    font-size: clamp(1.5rem, 2.2vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #004990;
    font-variant-numeric: tabular-nums;
  }
  .stats-row__label {
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 500;
    color: #9ca3af;
  }
  .stats-row__divider {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, transparent, #e2e8f0, transparent);
    flex-shrink: 0;
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #004990;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: gap 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .about-cta:hover {
    gap: 0.75rem;
  }

  /* scroll reveal */
  .about-section.reveal-ready .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .about-section.reveal-ready .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .about-section.reveal-ready .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>(".about-section");
  if (section) {
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    section.classList.add("reveal-ready");
    const els = section.querySelectorAll<HTMLElement>(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    els.forEach((el, i) => {
      el.style.transitionDelay = `${i * 0.08}s`;
      io.observe(el);
    });

    // count-up on stats row
    const nums = section.querySelectorAll<HTMLElement>(".stats-row__num");
    if (!reduce) {
      nums.forEach((el) => {
        el.textContent = "0" + (el.dataset.suffix || "");
      });
      const countUp = (el: HTMLElement) => {
        const target = parseInt(el.dataset.num || "0", 10);
        const suffix = el.dataset.suffix || "";
        const duration = 1400;
        const start = performance.now();
        const step = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = target + suffix;
        };
        requestAnimationFrame(step);
      };
      const countObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              countUp(e.target as HTMLElement);
              countObs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.5 },
      );
      nums.forEach((el) => countObs.observe(el));
    }
  }
</script>
