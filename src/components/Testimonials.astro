---
const items = [
  {
    logo: "/customer_logos/telekom-logo-2013.svg",
    company: "Deutsche Telekom",
    quote:
      "Durch den CreaLog AI Voice Agent konnten wir unsere First Call Resolution um 34 % steigern — bei gleichzeitig deutlich reduzierten Bearbeitungszeiten. Die Integration in unser bestehendes CRM war reibungslos.",
    name: "Anna Vogel",
    role: "Head of Customer Experience, Enterprise Customer Group",
    initials: "AV",
    logoH: 30,
  },
  {
    logo: "/customer_logos/logo-swisscom.svg",
    company: "Swisscom",
    quote:
      "CreaLog hat unsere Sprachdialoge auf ein neues Niveau gehoben. Die Erkennung funktioniert auch über Dialekte hinweg zuverlässig — für den Schweizer Markt war genau das entscheidend.",
    name: "Lukas Brunner",
    role: "Head of Contact Center Operations",
    initials: "LB",
    logoH: 40,
  },
  {
    logo: "/customer_logos/a1_logo.jpg",
    company: "A1 Telekom Austria",
    quote:
      "Wir haben 40 % der Standardanfragen vollautomatisiert. Der Voice Agent läuft DSGVO-konform in unserem eigenen Rechenzentrum — Skalierung ohne Kompromisse bei Compliance.",
    name: "Julia Hofer",
    role: "Director Customer Service",
    initials: "JH",
    logoH: 34,
    coloredBg: true,
  },
];
---

<section class="ts-section">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Centered header -->
    <div class="reveal max-w-3xl mx-auto text-center mb-12">
      <span
        class="inline-block text-[#1d4ed8] text-[12px] font-bold uppercase tracking-[0.22em] mb-4"
        >Kundenstimmen</span
      >
      <h2
        class="text-[2rem] lg:text-[2.9rem] font-extrabold leading-[1.1] tracking-[-0.03em] text-[#09090b]"
      >
        Was Europas führende Telcos sagen
      </h2>
      <p class="mt-[1.1rem] text-[16px] text-[#5b6472] leading-[1.7]">
        Von der Deutschen Telekom bis Swisscom — warum Carrier auf CreaLog
        setzen.
      </p>
    </div>

    <!-- Dark testimonial card with logo tabs -->
    <div class="ts-card reveal">
      <div class="ts-stage">
        {
          items.map((it, i) => (
            <figure class:list={["ts-slide", i === 0 && "is-active"]}>
              <div class="ts-avatar">{it.initials}</div>
              <blockquote class="ts-quote">“{it.quote}”</blockquote>
              <figcaption class="ts-cap">
                <div class="ts-name">
                  {it.name} <span class="ts-sep">//</span> {it.company}
                </div>
                <div class="ts-role">{it.role}</div>
              </figcaption>
            </figure>
          ))
        }
      </div>

      <div class="ts-logos">
        {
          items.map((it, i) => (
            <button
              type="button"
              class:list={["ts-logo", i === 0 && "is-active", it.coloredBg && "ts-logo--colored"]}
              aria-label={it.company}
            >
              <img src={it.logo} alt={it.company} style={`height:${it.logoH}px`} />
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .ts-section {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: #fff;
    padding: 6rem 0;
  }

  .ts-card {
    border-radius: 14px;
    background: #0a0a0b;
    overflow: hidden;
  }

  /* quote stage — slides cross-fade */
  .ts-stage {
    position: relative;
    min-height: 440px;
  }
  .ts-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.75rem;
    padding: 3.5rem 2rem;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease;
  }
  .ts-slide.is-active {
    opacity: 1;
    visibility: visible;
  }

  .ts-avatar {
    width: 58px;
    height: 58px;
    border-radius: 9999px;
    background: #1b1b1e;
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .ts-quote {
    max-width: 660px;
    margin: 0;
    font-size: clamp(1.1rem, 1.9vw, 1.5rem);
    line-height: 1.6;
    font-style: italic;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.92);
  }

  .ts-cap {
    margin-top: 0.25rem;
  }
  .ts-name {
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .ts-sep {
    color: rgba(255, 255, 255, 0.35);
    margin: 0 0.15rem;
  }
  .ts-role {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
    line-height: 1.5;
    margin-top: 0.3rem;
    max-width: 320px;
    margin-left: auto;
    margin-right: auto;
  }

  /* logo strip (black & white) */
  .ts-logos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .ts-logo {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.25rem 1rem;
    background: transparent;
    border: none;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    cursor: pointer;
  }
  .ts-logo:first-child {
    border-left: none;
  }
  .ts-logo img {
    width: auto;
    /* force monochrome white, dim when inactive */
    filter: brightness(0) invert(1);
    opacity: 0.32;
    transition: opacity 0.25s ease;
  }
  .ts-logo:hover img {
    opacity: 0.6;
  }
  .ts-logo.is-active img {
    opacity: 1;
  }
  .ts-logo.is-active {
    background: rgba(255, 255, 255, 0.035);
  }

  /* JPG with white bg: invert→white becomes black, saturate(0)→removes color,
     brightness(10)→all non-black grey tones clip to white = monochrome like others */
  .ts-logo--colored img {
    filter: invert(1) saturate(0) brightness(10);
    opacity: 0.32;
  }
  .ts-logo--colored:hover img {
    opacity: 0.6;
  }
  .ts-logo--colored.is-active img {
    opacity: 1;
  }
  .ts-logo.is-active::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: #fff;
  }

  @media (max-width: 640px) {
    .ts-logos {
      grid-template-columns: repeat(3, 1fr);
    }
    .ts-logo {
      padding: 1.5rem 0.5rem;
    }
    .ts-logo img {
      max-height: 26px;
    }
  }

  /* scroll reveal */
  .ts-section.reveal-ready .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ts-section.reveal-ready .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .ts-section.reveal-ready .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .ts-slide {
      transition: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>(".ts-section");
  if (section) {
    // ── tabs / autoplay ──────────────────────────────────────────
    const card = section.querySelector(".ts-card");
    if (card) {
      const slides = Array.from(card.querySelectorAll<HTMLElement>(".ts-slide"));
      const logos = Array.from(card.querySelectorAll<HTMLElement>(".ts-logo"));
      let active = 0;
      let timer: number | undefined;

      const show = (i: number) => {
        active = i;
        slides.forEach((s, idx) => s.classList.toggle("is-active", idx === i));
        logos.forEach((l, idx) => l.classList.toggle("is-active", idx === i));
      };
      const reduce = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const restart = () => {
        if (reduce) return;
        if (timer) clearInterval(timer);
        timer = window.setInterval(
          () => show((active + 1) % slides.length),
          6000,
        );
      };

      logos.forEach((l, i) =>
        l.addEventListener("click", () => {
          show(i);
          restart();
        }),
      );
      restart();
    }

    // ── scroll reveal ────────────────────────────────────────────
    section.classList.add("reveal-ready");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    section
      .querySelectorAll<HTMLElement>(".reveal")
      .forEach((el) => io.observe(el));
  }
</script>
