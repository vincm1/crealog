---
interface Props {
  quote: string;
  name: string;
  title: string;
  company: string;
  initials: string;
  avatarColor?: string;
  rating?: number;
  index?: number;
}
const {
  quote,
  name,
  title,
  company,
  initials,
  avatarColor = "#004990",
  rating = 5,
  index = 0,
} = Astro.props;
---

<article
  class="testimonial-card relative flex flex-col gap-6 rounded-2xl border border-gray-100 bg-white p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
  style={`animation-delay: ${index * 0.12}s`}
>
  <!-- Decorative quote mark -->
  <span
    class="absolute -top-1 left-6 font-serif text-[72px] leading-none text-[rgb(252,176,64)] opacity-60 select-none pointer-events-none"
    aria-hidden="true">"</span>

  <!-- Quote -->
  <blockquote class="pt-8 text-[15px] font-normal leading-relaxed text-gray-600">
    {quote}
  </blockquote>

  <!-- Divider -->
  <div class="h-px w-full bg-gray-100"></div>

  <!-- Author row -->
  <div class="flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <!-- Avatar -->
      <div
        class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full text-[12px] font-bold text-white"
        style={`background: ${avatarColor};`}
      >
        {initials}
      </div>
      <!-- Name + title -->
      <div class="flex flex-col">
        <span class="text-[13.5px] font-semibold text-gray-900">{name}</span>
        <span class="text-[12px] text-gray-400">{title} · {company}</span>
      </div>
    </div>

    <!-- Stars -->
    <div class="flex items-center gap-0.5 flex-shrink-0">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          class={`w-3.5 h-3.5 ${i < rating ? "text-[rgb(252,176,64)]" : "text-gray-200"}`}
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      ))}
    </div>
  </div>
</article>

<style>
  .testimonial-card {
    opacity: 0;
    animation: cardFadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes cardFadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
