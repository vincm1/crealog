---
import CXSolution from "./CXSolution.astro";
import TelcoSolutions from "./TelcoSolutions.astro";
import ProfessionalServices from "./ProfessionalServices.astro";
import MobileMenu from "./MobileMenu.astro";
import LangToggler from "../LangToggler.astro";

const isElegant = Astro.url.pathname === "/elegant";
---

<style>
  /* black pill CTA — mirrors the hero button's hover language */
  .nav-cta {
    position: relative;
    overflow: hidden;
    align-items: center;
    gap: 0.45rem;
    background: #09090b;
    color: #fff;
    font-size: 13.5px;
    font-weight: 600;
    padding: 0.55rem 1.25rem;
    border-radius: 99px;
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease;
  }
  .nav-cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.16) 50%,
      transparent 70%
    );
    transform: translateX(-130%);
  }
  .nav-cta:hover {
    background: #18181b;
    transform: translateY(-1px);
    box-shadow:
      0 6px 20px rgba(29, 78, 216, 0.3),
      0 2px 8px rgba(9, 9, 11, 0.2);
  }
  .nav-cta:hover::after {
    transition: transform 0.6s ease;
    transform: translateX(130%);
  }
  .nav-cta:active {
    transform: translateY(0) scale(0.97);
  }
  .nav-cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-cta:hover .nav-cta-arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-cta:hover::after {
      transition: none;
      transform: translateX(-130%);
    }
    .nav-cta:hover .nav-cta-arrow {
      transform: none;
    }
  }
</style>

<div
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-xl border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center h-16">
    <!-- Logo -->
    <a href="/" class="flex-none">
      <img src="/crealog_logo.png" alt="CreaLog" class="h-8 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-0.5 mx-auto">
      <!-- CX Solutions Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          CX Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <CXSolution />
          </div>
        </div>
      </div>

      <!-- IN Solutions Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Telco Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[900px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <TelcoSolutions />
          </div>
        </div>
      </div>

      <!-- Professional Services Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Professional Services
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <ProfessionalServices />
          </div>
        </div>
      </div>

      <a
        href="/about"
        class="relative px-3 py-2 text-[13.5px] font-medium text-gray-600 hover:text-gray-900 rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Über uns</a
      >
      <a
        href="/blog"
        class="relative px-3 py-2 text-[13.5px] font-medium text-gray-600 hover:text-gray-900 rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Blog</a
      >
    </nav>

    <!-- Version switcher dropdown -->
    <div class="hidden lg:flex flex-none items-center mr-3 relative" id="variant-picker">
      <button
        id="variant-btn"
        class="flex items-center gap-1.5 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-full text-[11.5px] font-semibold text-gray-600 hover:text-gray-900 transition-colors duration-150 cursor-pointer"
        aria-haspopup="listbox"
        aria-expanded="false"
      >
        <span>{isElegant ? "Elegant" : "Current"}</span>
        <svg
          id="variant-chevron"
          class="w-3 h-3 text-gray-400 transition-transform duration-200"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
      <div
        id="variant-panel"
        class="absolute top-full right-0 mt-1.5 bg-white rounded-xl shadow-lg shadow-black/[0.06] border border-gray-100 p-1 w-[116px] hidden z-50"
        role="listbox"
      >
        <a
          href="/"
          class={`flex items-center justify-between px-3 py-1.5 rounded-lg text-[12px] font-medium transition-colors hover:bg-gray-50 ${!isElegant ? "text-gray-900" : "text-gray-400"}`}
          role="option"
          aria-selected={!isElegant}
        >
          Current
          {!isElegant && (
            <svg class="w-3.5 h-3.5 text-blue-600 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5" />
            </svg>
          )}
        </a>
        <a
          href="/elegant"
          class={`flex items-center justify-between px-3 py-1.5 rounded-lg text-[12px] font-medium transition-colors hover:bg-gray-50 ${isElegant ? "text-gray-900" : "text-gray-400"}`}
          role="option"
          aria-selected={isElegant}
        >
          Elegant
          {isElegant && (
            <svg class="w-3.5 h-3.5 text-blue-600 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5" />
            </svg>
          )}
        </a>
      </div>
    </div>

    <!-- Desktop language toggle -->
    <div class="hidden lg:block flex-none mr-4">
      <LangToggler />
    </div>

    <!-- Desktop CTA -->
    <a href="/kontakt" class="nav-cta hidden lg:inline-flex flex-none">
      Kontakt aufnehmen
      <svg
        class="nav-cta-arrow"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="M12 5l7 7-7 7"></path>
      </svg>
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden ml-auto p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors"
      aria-label="Menü öffnen"
    >
      <svg
        id="hamburger-icon"
        class="w-5 h-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h8m-8 6h16"></path>
      </svg>
      <svg
        id="close-icon"
        class="w-5 h-5 hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</div>

<!-- Mobile Menu -->
<MobileMenu />

<script>
  const btn = document.getElementById("variant-btn");
  const panel = document.getElementById("variant-panel");
  const chevron = document.getElementById("variant-chevron");

  if (btn && panel && chevron) {
    const open = () => {
      panel.classList.remove("hidden");
      chevron.classList.add("rotate-180");
      btn.setAttribute("aria-expanded", "true");
    };
    const close = () => {
      panel.classList.add("hidden");
      chevron.classList.remove("rotate-180");
      btn.setAttribute("aria-expanded", "false");
    };

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      panel.classList.contains("hidden") ? open() : close();
    });
    document.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }
</script>
