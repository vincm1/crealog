---
import CXSolution from "./CXSolution.astro";
import INSolution from "./INSolution.astro";
---

<div class="navbar bg-base-100 shadow-sm">

  <!-- Logo: immer links -->
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost text-xl font-bold">Crealog</a>
  </div>

  <!-- Desktop-Links: mittig, auf Mobile ausgeblendet -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1">
      <li>
        <details>
          <summary>CX Solutions</summary>
          <CXSolution />
        </details>
      </li>
      <li>
        <details>
          <summary>IN Solutions</summary>
          <INSolution />
        </details>
      </li>
      <li><a href="/about">Über uns</a></li>
      <li><a href="/kontakt">Kontakt</a></li>
    </ul>
  </div>

  <!-- Ende: CTA (Desktop) + Hamburger (Mobile) -->
  <div class="navbar-end gap-2">

    <!-- CTA-Button: nur Desktop -->
    <a href="/kontakt" class="btn btn-primary hidden lg:flex">Kontakt aufnehmen</a>

    <!-- Hamburger: nur Mobile -->
    <div class="dropdown dropdown-end lg:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h8m-8 6h16"
          ></path>
        </svg>
      </div>
      <ul
        tabindex="0"
        class="menu menu-sm dropdown-content bg-base-100 rounded-box z-10 mt-3 w-56 p-2 shadow"
      >
        <li>
          <details>
            <summary>CX Solutions</summary>
            <CXSolution />
          </details>
        </li>
        <li>
          <details>
            <summary>IN Solutions</summary>
            <INSolution />
          </details>
        </li>
        <li><a href="/about">Über uns</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </div>

  </div>
</div>
