---
import CXSolution from "./CXSolution.astro";
import INSolution from "./INSolution.astro";
import ProfessionalServices from "./ProfessionalServices.astro";
import LangToggler from "../LangToggler.astro";
---

<style>
  /* black pill CTA — mirrors the hero button's hover language */
  .nav-cta {
    position: relative;
    overflow: hidden;
    align-items: center;
    gap: 0.45rem;
    background: #09090b;
    color: #fff;
    font-size: 13.5px;
    font-weight: 600;
    padding: 0.55rem 1.25rem;
    border-radius: 99px;
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease;
  }
  .nav-cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.16) 50%,
      transparent 70%
    );
    transform: translateX(-130%);
  }
  .nav-cta:hover {
    background: #18181b;
    transform: translateY(-1px);
    box-shadow:
      0 6px 20px rgba(29, 78, 216, 0.3),
      0 2px 8px rgba(9, 9, 11, 0.2);
  }
  .nav-cta:hover::after {
    transition: transform 0.6s ease;
    transform: translateX(130%);
  }
  .nav-cta:active {
    transform: translateY(0) scale(0.97);
  }
  .nav-cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-cta:hover .nav-cta-arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-cta:hover::after {
      transition: none;
      transform: translateX(-130%);
    }
    .nav-cta:hover .nav-cta-arrow {
      transform: none;
    }
  }
</style>

<div
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-xl border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center h-16">
    <!-- Logo -->
    <a href="/" class="flex-none">
      <img src="/crealog_logo.png" alt="CreaLog" class="h-8 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-0.5 mx-auto">
      <!-- CX Solutions Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          CX Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <CXSolution />
          </div>
        </div>
      </div>

      <!-- IN Solutions Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Telco Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[500px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <INSolution />
          </div>
        </div>
      </div>

      <!-- Professional Services Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Professional Services
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <ProfessionalServices />
          </div>
        </div>
      </div>

      <a
        href="/about"
        class="relative px-3 py-2 text-[13.5px] font-medium text-gray-600 hover:text-gray-900 rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Über uns</a
      >
      <a
        href="/blog"
        class="relative px-3 py-2 text-[13.5px] font-medium text-gray-600 hover:text-gray-900 rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Blog</a
      >
    </nav>

    <!-- Desktop language toggle -->
    <div class="hidden lg:block flex-none mr-4">
      <LangToggler />
    </div>

    <!-- Desktop CTA -->
    <a href="/kontakt" class="nav-cta hidden lg:inline-flex flex-none">
      Kontakt aufnehmen
      <svg
        class="nav-cta-arrow"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="M12 5l7 7-7 7"></path>
      </svg>
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden ml-auto p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors"
      aria-label="Menü öffnen"
    >
      <svg
        id="hamburger-icon"
        class="w-5 h-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h8m-8 6h16"></path>
      </svg>
      <svg
        id="close-icon"
        class="w-5 h-5 hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</div>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="hidden lg:hidden border-t border-gray-100 bg-white"
>
  <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-0.5">
    <!-- CX Solutions -->
    <button
      id="cx-toggle"
      class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 text-left"
    >
      CX Solutions
      <svg
        id="cx-chevron"
        class="w-4 h-4 text-gray-400 transition-transform duration-200"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </button>
    <div id="cx-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >AI Voice Agent</a
      >
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >Chat Assistant</a
      >
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >Omnichannel-Routing</a
      >
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >Speech Analytics</a
      >
    </div>

    <!-- IN Solutions -->
    <button
      id="in-toggle"
      class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 text-left"
    >
      Telco Solutions
      <svg
        id="in-chevron"
        class="w-4 h-4 text-gray-400 transition-transform duration-200"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </button>
    <div id="in-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >ASR / TTS</a
      >
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >NLU-Engine</a
      >
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >API & SDK</a
      >
    </div>

    <!-- Professional Services -->
    <button
      id="ps-toggle"
      class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 text-left"
    >
      Professional Services
      <svg
        id="ps-chevron"
        class="w-4 h-4 text-gray-400 transition-transform duration-200"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </button>
    <div id="ps-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >Consulting</a
      >
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >Integration</a
      >
      <a
        href="#"
        class="px-3 py-2 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50"
        >Support</a
      >
    </div>

    <a
      href="/about"
      class="px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50"
      >Über uns</a
    >
    <a
      href="/blog"
      class="px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50"
      >Blog</a
    >

    <div class="pt-3 mt-1 border-t border-gray-100">
      @
      <a
        href="/kontakt"
        class="flex justify-center items-center py-2.5 bg-[#09090b] text-white text-sm font-semibold rounded-full hover:bg-[#18181b] transition-colors"
      >
        Kontakt aufnehmen
      </a>
    </div>
  </nav>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const burger = document.getElementById("hamburger-icon");
  const cross = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const open = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", open);
    burger?.classList.toggle("hidden", !open);
    cross?.classList.toggle("hidden", open);
  });

  function mobileSubmenu(toggleId: string, subId: string, chevronId: string) {
    document.getElementById(toggleId)?.addEventListener("click", () => {
      document.getElementById(subId)?.classList.toggle("hidden");
      document.getElementById(chevronId)?.classList.toggle("rotate-180");
    });
  }
  mobileSubmenu("cx-toggle", "cx-sub", "cx-chevron");
  mobileSubmenu("in-toggle", "in-sub", "in-chevron");
  mobileSubmenu("ps-toggle", "ps-sub", "ps-chevron");
</script>
