---
import CXSolution from "./CXSolution.astro";
import TelcoSolutions from "./TelcoSolutions.astro";
import ProfessionalServices from "./ProfessionalServices.astro";
import MobileMenu from "./MobileMenu.astro";
import LangToggler from "../LangToggler.astro";

const { darkHero = false } = Astro.props;
---

<style>
  /* ── Wrapper ────────────────────────────────────── */
  .navbar-root {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgb(243, 244, 246);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      backdrop-filter 0.35s ease;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }

  /* ── Logo ───────────────────────────────────────── */
  .nav-logo {
    transition: filter 0.35s ease;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-logo {
    filter: brightness(0) invert(1);
  }

  /* ── Nav buttons (dropdown triggers) ───────────── */
  .nav-item-btn {
    transition: color 0.3s ease;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-item-btn {
    color: rgba(255, 255, 255, 0.75);
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .group:hover .nav-item-btn {
    color: #fff;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-item-btn svg {
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.2s ease;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .group:hover .nav-item-btn svg {
    color: #38a8ff;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-item-btn::after {
    background-color: #38a8ff;
  }

  /* ── Nav links (Über uns, Blog) ─────────────────── */
  .nav-item-link {
    transition: color 0.3s ease;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-item-link {
    color: rgba(255, 255, 255, 0.75);
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-item-link:hover {
    color: #fff;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-item-link::after {
    background-color: #38a8ff;
  }

  /* ── Mobile hamburger ───────────────────────────── */
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] #mobile-menu-btn {
    color: rgba(255, 255, 255, 0.8);
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] #mobile-menu-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  /* ── CTA pill ───────────────────────────────────── */
  .nav-cta {
    position: relative;
    overflow: hidden;
    align-items: center;
    gap: 0.45rem;
    background: #09090b;
    color: #fff;
    font-size: 13.5px;
    font-weight: 600;
    padding: 0.55rem 1.25rem;
    border-radius: 99px;
    border: 1px solid transparent;
    text-decoration: none;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease;
  }
  .nav-cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.16) 50%,
      transparent 70%
    );
    transform: translateX(-130%);
  }
  .nav-cta:hover {
    background: #18181b;
    transform: translateY(-1px);
    box-shadow:
      0 6px 20px rgba(29, 78, 216, 0.3),
      0 2px 8px rgba(9, 9, 11, 0.2);
  }
  .nav-cta:hover::after {
    transition: transform 0.6s ease;
    transform: translateX(130%);
  }
  .nav-cta:active {
    transform: translateY(0) scale(0.97);
  }
  .nav-cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-cta:hover .nav-cta-arrow {
    transform: translateX(3px);
  }

  /* CTA in dark/hero mode */
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-cta {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.28);
    color: #fff;
  }
  .navbar-root[data-dark-hero="true"][data-scrolled="false"] .nav-cta:hover {
    background: rgba(255, 255, 255, 0.18);
    box-shadow: 0 4px 20px rgba(56, 168, 255, 0.25);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-cta:hover::after {
      transition: none;
      transform: translateX(-130%);
    }
    .nav-cta:hover .nav-cta-arrow {
      transform: none;
    }
  }
</style>

<div
  id="navbar"
  data-dark-hero={darkHero ? "true" : "false"}
  data-scrolled="false"
  class="navbar-root fixed top-0 left-0 right-0 z-50"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center h-16">
    <!-- Logo -->
    <a href="/" class="flex-none">
      <img src="/crealog_logo.png" alt="CreaLog" class="nav-logo h-8 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-0.5 mx-auto">
      <!-- CX Solutions Mega -->
      <div class="relative group">
        <button
          class="nav-item-btn relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          CX Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <CXSolution />
          </div>
        </div>
      </div>

      <!-- Telco Solutions Mega -->
      <div class="relative group">
        <button
          class="nav-item-btn relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Telco Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[900px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <TelcoSolutions />
          </div>
        </div>
      </div>

      <!-- Professional Services Mega -->
      <div class="relative group">
        <button
          class="nav-item-btn relative flex items-center gap-1.5 px-3 py-2 text-[13.5px] font-medium text-gray-600 group-hover:text-gray-900 rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Professional Services
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-gray-400 group-hover:text-[#1d4ed8]"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <ProfessionalServices />
          </div>
        </div>
      </div>

      <a
        href="/about"
        class="nav-item-link relative px-3 py-2 text-[13.5px] font-medium text-gray-600 hover:text-gray-900 rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Über uns</a
      >
      <a
        href="/blog"
        class="nav-item-link relative px-3 py-2 text-[13.5px] font-medium text-gray-600 hover:text-gray-900 rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:rounded-full after:bg-[#1d4ed8] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Blog</a
      >
    </nav>

    <!-- Desktop language toggle -->
    <div class="hidden lg:block flex-none mr-4">
      <LangToggler />
    </div>

    <!-- Desktop CTA -->
    <a href="/kontakt" class="nav-cta hidden lg:inline-flex flex-none">
      Kontakt aufnehmen
      <svg
        class="nav-cta-arrow"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="M12 5l7 7-7 7"></path>
      </svg>
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden ml-auto p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors"
      aria-label="Menü öffnen"
    >
      <svg
        id="hamburger-icon"
        class="w-5 h-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h8m-8 6h16"></path>
      </svg>
      <svg
        id="close-icon"
        class="w-5 h-5 hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</div>

<!-- Mobile Menu -->
<MobileMenu />

<script>
  const navbar = document.getElementById("navbar");

  // Scroll-to-white logic (only active on dark-hero pages)
  if (navbar && navbar.dataset.darkHero === "true") {
    const update = () => {
      navbar.setAttribute("data-scrolled", window.scrollY > 80 ? "true" : "false");
    };
    window.addEventListener("scroll", update, { passive: true });
    update();
  } else if (navbar) {
    // Non-hero pages: always show white navbar
    navbar.setAttribute("data-scrolled", "true");
  }
</script>
