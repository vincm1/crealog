---
import CXSolution from "./CXSolution.astro";
import INSolution from "./INSolution.astro";
import ProfessionalServices from "./ProfessionalServices.astro";
---

<div
  class="fixed top-0 left-0 right-0 z-50 bg-[#050d1e]/95 backdrop-blur-xl border-b border-white/10"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center h-16">
    <!-- Logo (invertiert für dunklen Hintergrund) -->
    <a href="/" class="flex-none">
      <img
        src="/crealog_logo.png"
        alt="CreaLog"
        class="h-8 w-auto brightness-0 invert"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-0.5 mx-auto">
      <!-- CX Solutions Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-2 py-2 text-[13.5px] font-medium text-white/65 group-hover:text-white rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-2 after:right-2 after:h-[2px] after:rounded-full after:bg-[rgb(252,176,64)] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          CX Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-white/35 group-hover:text-white/70"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <CXSolution />
          </div>
        </div>
      </div>

      <!-- IN Solutions Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-2 py-2 text-[13.5px] font-medium text-white/65 group-hover:text-white rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-2 after:right-2 after:h-[2px] after:rounded-full after:bg-[rgb(252,176,64)] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Telco Solutions
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-white/35 group-hover:text-white/70"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[500px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <INSolution />
          </div>
        </div>
      </div>

      <!-- Professional Services Mega -->
      <div class="relative group">
        <button
          class="relative flex items-center gap-1.5 px-2 py-2 text-[13.5px] font-medium text-white/65 group-hover:text-white rounded-lg transition-colors duration-150 whitespace-nowrap after:absolute after:bottom-0 after:left-2 after:right-2 after:h-[2px] after:rounded-full after:bg-[rgb(252,176,64)] after:scale-x-0 group-hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >
          Professional Services
          <svg
            class="w-[14px] h-[14px] transition-transform duration-200 group-hover:rotate-180 text-white/35 group-hover:text-white/70"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-2 invisible pointer-events-none opacity-0 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 transition-all duration-150 z-50 w-[700px]"
        >
          <div
            class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5"
          >
            <ProfessionalServices />
          </div>
        </div>
      </div>

      <a
        href="/about"
        class="relative px-2 py-2 text-[13.5px] font-medium text-white/65 hover:text-white rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-2 after:right-2 after:h-[2px] after:rounded-full after:bg-[rgb(252,176,64)] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Über uns</a
      >
      <a
        href="/kontakt"
        class="relative px-2 py-2 text-[13.5px] font-medium text-white/65 hover:text-white rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-2 after:right-2 after:h-[2px] after:rounded-full after:bg-[rgb(252,176,64)] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Kontakt</a
      >
      <a
        href="/blog"
        class="relative px-2 py-2 text-[13.5px] font-medium text-white/65 hover:text-white rounded-lg transition-colors duration-150 after:absolute after:bottom-0 after:left-2 after:right-2 after:h-[2px] after:rounded-full after:bg-[rgb(252,176,64)] after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-left"
        >Blog</a
      >
    </nav>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-3 ml-auto">
      <a
        href="/kontakt"
        class="hidden lg:inline-flex items-center px-5 py-2.5 bg-[#004990] text-white text-sm font-semibold rounded-full hover:bg-[#003a73] transition-colors duration-150"
      >
        Kontakt aufnehmen
      </a>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-white/70 hover:bg-white/10 transition-colors"
        aria-label="Menü öffnen"
      >
        <svg
          id="hamburger-icon"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h8m-8 6h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-5 h-5 hidden"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-white/10 bg-[#050d1e]"
  >
    <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-0.5">
      <!-- CX Solutions -->
      <button
        id="cx-toggle"
        class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-white/70 hover:text-white rounded-lg hover:bg-white/5 text-left"
      >
        CX Solutions
        <svg
          id="cx-chevron"
          class="w-4 h-4 text-white/35 transition-transform duration-200"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
            clip-rule="evenodd"></path>
        </svg>
      </button>
      <div id="cx-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
        <a
          href="#"
          class="px-3 py-2 text-sm text-white/55 hover:text-white rounded-lg hover:bg-white/5"
          >AI Voice Agent</a
        >
        <a
          href="#"
          class="px-3 py-2 text-sm text-white/55 hover:text-white rounded-lg hover:bg-white/5"
          >Chat Assistant</a
        >
        <a
          href="#"
          class="px-3 py-2 text-sm text-white/55 hover:text-white rounded-lg hover:bg-white/5"
          >Omnichannel-Routing</a
        >
        <a
          href="#"
          class="px-3 py-2 text-sm text-white/55 hover:text-white rounded-lg hover:bg-white/5"
          >Speech Analytics</a
        >
      </div>

      <!-- IN Solutions -->
      <button
        id="in-toggle"
        class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-white/70 hover:text-white rounded-lg hover:bg-white/5 text-left"
      >
        IN Solutions
        <svg
          id="in-chevron"
          class="w-4 h-4 text-white/35 transition-transform duration-200"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
            clip-rule="evenodd"></path>
        </svg>
      </button>
      <div id="in-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
        <a
          href="#"
          class="px-3 py-2 text-sm text-white/55 hover:text-white rounded-lg hover:bg-white/5"
          >ASR / TTS</a
        >
        <a
          href="#"
          class="px-3 py-2 text-sm text-white/55 hover:text-white rounded-lg hover:bg-white/5"
          >NLU-Engine</a
        >
        <a
          href="#"
          class="px-3 py-2 text-sm text-white/55 hover:text-white rounded-lg hover:bg-white/5"
          >API & SDK</a
        >
      </div>

      <a
        href="/about"
        class="px-3 py-2.5 text-sm font-medium text-white/70 hover:text-white rounded-lg hover:bg-white/5"
        >Über uns</a
      >
      <a
        href="/kontakt"
        class="px-3 py-2.5 text-sm font-medium text-white/70 hover:text-white rounded-lg hover:bg-white/5"
        >Kontakt</a
      >
      <a
        href="/blog"
        class="px-3 py-2.5 text-sm font-medium text-white/70 hover:text-white rounded-lg hover:bg-white/5"
        >Blog</a
      >

      <div class="pt-3 mt-1 border-t border-white/10">
        <a
          href="/kontakt"
          class="flex justify-center items-center py-2.5 bg-[#004990] text-white text-sm font-semibold rounded-full hover:bg-[#003a73] transition-colors"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </nav>
  </div>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const burger = document.getElementById("hamburger-icon");
  const cross = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const open = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", open);
    burger?.classList.toggle("hidden", !open);
    cross?.classList.toggle("hidden", open);
  });

  function mobileSubmenu(toggleId: string, subId: string, chevronId: string) {
    document.getElementById(toggleId)?.addEventListener("click", () => {
      document.getElementById(subId)?.classList.toggle("hidden");
      document.getElementById(chevronId)?.classList.toggle("rotate-180");
    });
  }
  mobileSubmenu("cx-toggle", "cx-sub", "cx-chevron");
  mobileSubmenu("in-toggle", "in-sub", "in-chevron");
</script>
