---
const { stories = [] } = Astro.props;
---
<div class="grid grid-cols-4 gap-3">
  <!-- Column 1: Dynamic stories from Storyblok -->
  <div class="bg-gray-50 rounded-xl p-5">
    <div class="flex items-center justify-between pb-3 mb-4 border-b border-gray-200">
      <span class="text-[12px] font-semibold text-gray-900">Service Delivery Platform</span>
      <svg class="w-5 h-5 text-[#004990] flex-none" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 2.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
      </svg>
    </div>
    <nav class="flex flex-col gap-3">
      {stories.length > 0 ? stories.map((story: any) => (
        <a href={`/${story.full_slug}`} class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">{story.name}</a>
      )) : (
        <span class="text-[13px] text-gray-400 italic">Demnächst verfügbar</span>
      )}
    </nav>
  </div>

  <!-- Column 2: Applications (hardcoded) -->
  <div class="bg-gray-50 rounded-xl p-5">
    <div class="flex items-center justify-between pb-3 mb-4 border-b border-gray-200">
      <span class="text-[12px] font-semibold text-gray-900">Applications</span>
      <svg class="w-5 h-5 text-[#004990] flex-none" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
      </svg>
    </div>
    <nav class="flex flex-col gap-3">
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">IN & SIP Services</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">AI Agent Marketplace</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">AI Agent projects</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">NG 112</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">Recording</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">Contact Center</a>
    </nav>
  </div>

  <!-- Column 3: Interfaces / Mediation (hardcoded) -->
  <div class="bg-gray-50 rounded-xl p-5">
    <div class="flex items-center justify-between pb-3 mb-4 border-b border-gray-200">
      <span class="text-[12px] font-semibold text-gray-900">Interfaces / Mediation</span>
      <svg class="w-5 h-5 text-[#004990] flex-none" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
      </svg>
    </div>
    <nav class="flex flex-col gap-3">
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">Mediation Devices</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">REST API</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">AI Connectors</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">Telco API</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">Provisioning API</a>
      <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">Webservices</a>
    </nav>
  </div>

  <!-- Column 4: References (hardcoded) -->
  <div class="bg-gray-50 rounded-xl p-5">
    <div class="flex items-center justify-between pb-3 mb-4 border-b border-gray-200">
      <span class="text-[12px] font-semibold text-gray-900">References</span>
      <svg class="w-5 h-5 text-[#004990] flex-none" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
      </svg>
    </div>
    <nav class="flex flex-col gap-3">
      {["Swisscom", "Unitel", "Vodafone", "Deutsche Telekom", "A1 Telekom Austria", "Kyivstar"].map((name) => (
        <a href="#" class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">{name}</a>
      ))}
    </nav>
  </div>
</div>
