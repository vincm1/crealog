---
// cxStories  -> AI-Solutions (cx-solutions/ = Bot-Unterseiten)
// telcoStories -> Plattform (telco-solutions/ = Service Delivery Platform)
const { cxStories = [], telcoStories = [] } = Astro.props;

type Group = { key: string; label: string; stories: any[] };

function groupStories(stories: any[]): Group[] {
  const map = new Map<string, Group>();
  for (const story of stories) {
    const parts = story.full_slug.split('/');
    const hasCategory = parts.length >= 3;
    const key = hasCategory ? parts[1] : '__root__';
    const label = hasCategory
      ? parts[1].split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
      : '';
    if (!map.has(key)) map.set(key, { key, label, stories: [] });
    map.get(key)!.stories.push(story);
  }
  return [...map.values()];
}

const cxGroups = groupStories(cxStories);
const telcoGroups = groupStories(telcoStories);

// Statische Branchen (spiegeln Industries.astro / IndustriesBlock)
const industries = [
  { title: "Carrier & Telcos", href: "/telco-solutions/service-delivery-platform" },
  { title: "Behörden & Verwaltung", href: "/about" },
  { title: "Banken & Versicherungen", href: "/about" },
  { title: "E-Mobilität", href: "/telco-solutions/service-delivery-platform" },
  { title: "Handel & Teleshopping", href: "/about" },
];

// Ressourcen (ersetzt Professional Services)
const resources = [
  { title: "Blog", href: "/blog" },
  { title: "Summit", href: "/summit" },
  { title: "Whitepaper & Downloads", href: "/downloads" },
  { title: "News & Events", href: "/news" },
];
---

<div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-0.5">

    <!-- Plattform -->
    <button id="plt-toggle" class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 text-left">
      Plattform
      <svg id="plt-chevron" class="w-4 h-4 text-gray-400 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    <div id="plt-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
      {telcoGroups.length > 0 ? telcoGroups.map((group) => (
        <>
          {group.label && (
            <span class="px-3 pt-2 pb-1 text-[11px] font-semibold text-gray-400 uppercase tracking-wider">{group.label}</span>
          )}
          {group.stories.map((story: any) => (
            <a href={`/${story.full_slug}`} class="px-3 py-1.5 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50">{story.name}</a>
          ))}
        </>
      )) : (
        <span class="px-3 py-2 text-sm text-gray-400 italic">Demnächst verfügbar</span>
      )}
    </div>

    <!-- AI-Solutions -->
    <button id="ai-toggle" class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 text-left">
      AI-Solutions
      <svg id="ai-chevron" class="w-4 h-4 text-gray-400 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    <div id="ai-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
      {cxGroups.length > 0 ? cxGroups.map((group) => (
        <>
          {group.label && (
            <span class="px-3 pt-2 pb-1 text-[11px] font-semibold text-gray-400 uppercase tracking-wider">{group.label}</span>
          )}
          {group.stories.map((story: any) => (
            <a href={`/${story.full_slug}`} class="px-3 py-1.5 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50">{story.name}</a>
          ))}
        </>
      )) : (
        <span class="px-3 py-2 text-sm text-gray-400 italic">Demnächst verfügbar</span>
      )}
    </div>

    <!-- Industries -->
    <button id="ind-toggle" class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 text-left">
      Industries
      <svg id="ind-chevron" class="w-4 h-4 text-gray-400 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    <div id="ind-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
      {industries.map((ind) => (
        <a href={ind.href} class="px-3 py-1.5 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50">{ind.title}</a>
      ))}
    </div>

    <!-- About -->
    <a href="/about" class="px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50">About</a>

    <!-- Ressourcen -->
    <button id="res-toggle" class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 text-left">
      Ressourcen
      <svg id="res-chevron" class="w-4 h-4 text-gray-400 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
    <div id="res-sub" class="hidden pl-3 flex flex-col gap-0.5 pb-1">
      {resources.map((res) => (
        <a href={res.href} class="px-3 py-1.5 text-sm text-gray-500 hover:text-gray-900 rounded-lg hover:bg-gray-50">{res.title}</a>
      ))}
    </div>

    <div class="pt-3 mt-1 border-t border-gray-100">
      <a href="/kontakt" class="flex justify-center items-center py-2.5 bg-[#09090b] text-white text-sm font-semibold rounded-full hover:bg-[#18181b] transition-colors">
        Kontakt aufnehmen
      </a>
    </div>
  </nav>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const burger = document.getElementById("hamburger-icon");
  const cross = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const open = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", open);
    burger?.classList.toggle("hidden", !open);
    cross?.classList.toggle("hidden", open);
  });

  function mobileSubmenu(toggleId: string, subId: string, chevronId: string) {
    document.getElementById(toggleId)?.addEventListener("click", () => {
      document.getElementById(subId)?.classList.toggle("hidden");
      document.getElementById(chevronId)?.classList.toggle("rotate-180");
    });
  }
  mobileSubmenu("plt-toggle", "plt-sub", "plt-chevron");
  mobileSubmenu("ai-toggle", "ai-sub", "ai-chevron");
  mobileSubmenu("ind-toggle", "ind-sub", "ind-chevron");
  mobileSubmenu("res-toggle", "res-sub", "res-chevron");
</script>
