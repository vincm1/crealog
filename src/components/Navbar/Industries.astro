---
// Statisches Industries-Mega-Dropdown — spiegelt die 5 Branchen aus dem
// Startseiten-`IndustriesBlock`. Bilder + Link-Ziele bewusst identisch gehalten,
// damit Nav und Startseite konsistent bleiben.
const industries = [
  {
    title: "Carrier & Telcos",
    eyebrow: "Carrier grade",
    image: "/industries/telecommunication_infrastructure_photo.png",
    href: "/telco-solutions/service-delivery-platform",
  },
  {
    title: "Behörden & Verwaltung",
    eyebrow: "Trust first",
    image: "/industries/photo_of_a_public_authority_building.png",
    href: "/about",
  },
  {
    title: "Banken & Versicherungen",
    eyebrow: "Compliance",
    image: "/industries/banking_operations_or_privat.png",
    href: "/about",
  },
  {
    title: "E-Mobilität",
    eyebrow: "Connected",
    image: "/industries/EV_charging_location_with_multiple_cars.png",
    href: "/telco-solutions/service-delivery-platform",
  },
  {
    title: "Handel & Teleshopping",
    eyebrow: "High volume",
    image: "/industries/teleshopping_broadcast_studio.png",
    href: "/about",
  },
];
---

<div class="grid grid-cols-2 gap-2">
  {industries.map((ind) => (
    <a
      href={ind.href}
      class="group/ind flex items-center gap-3 p-2.5 rounded-xl hover:bg-gray-50 transition-colors"
    >
      <span class="relative flex-none w-14 h-14 rounded-lg overflow-hidden">
        <img
          src={ind.image}
          alt={ind.title}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover/ind:scale-105"
          loading="lazy"
        />
        <span class="absolute inset-0 bg-[#0a1628]/25"></span>
      </span>
      <span class="flex flex-col">
        <span class="text-[10px] font-bold uppercase tracking-wider text-[#1d6bbf]">
          {ind.eyebrow}
        </span>
        <span class="text-[13px] font-semibold text-gray-900 group-hover/ind:text-[#004081] transition-colors">
          {ind.title}
        </span>
      </span>
    </a>
  ))}

  <!-- Übersichts-Zelle füllt das 6. Feld -->
  <a
    href="/#industries"
    class="group/all flex items-center justify-between gap-3 p-2.5 rounded-xl bg-gray-50 hover:bg-[#004081] transition-colors"
  >
    <span class="flex flex-col">
      <span class="text-[10px] font-bold uppercase tracking-wider text-[#1d6bbf] group-hover/all:text-white/70">
        Überblick
      </span>
      <span class="text-[13px] font-semibold text-gray-900 group-hover/all:text-white transition-colors">
        Alle Branchen
      </span>
    </span>
    <svg
      class="w-4 h-4 flex-none text-[#004081] group-hover/all:text-white transition-transform duration-200 group-hover/all:translate-x-0.5"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </a>
</div>
