---
const { stories = [] } = Astro.props;

type Group = { key: string; label: string; stories: any[] };

function groupStories(stories: any[]): Group[] {
  const map = new Map<string, Group>();
  for (const story of stories) {
    const parts = story.full_slug.split('/');
    const hasCategory = parts.length >= 3;
    const key = hasCategory ? parts[1] : '__root__';
    const label = hasCategory
      ? parts[1].split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
      : '';
    if (!map.has(key)) map.set(key, { key, label, stories: [] });
    map.get(key)!.stories.push(story);
  }
  return [...map.values()];
}

const groups = groupStories(stories);
const cols = Math.min(Math.max(groups.length, 1), 3);

const ICONS = [
  "M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z",
  "M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z",
  "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z",
];
---

{groups.length > 0 ? (
  <div class="grid gap-3" style={`grid-template-columns: repeat(${cols}, minmax(0, 1fr))`}>
    {groups.map((group, i) => (
      <div class="bg-gray-50 rounded-xl p-5">
        {group.label && (
          <div class="flex items-center justify-between pb-3 mb-4 border-b border-gray-200">
            <span class="text-[13px] font-semibold text-gray-900">{group.label}</span>
            <svg class="w-5 h-5 text-[#004990] flex-none" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d={ICONS[i % ICONS.length]} />
            </svg>
          </div>
        )}
        <nav class="flex flex-col gap-3">
          {group.stories.map((story: any) => (
            <a href={`/${story.full_slug}`} class="text-[13px] font-medium text-gray-700 hover:text-[#004990] transition-colors">
              {story.name}
            </a>
          ))}
        </nav>
      </div>
    ))}
  </div>
) : (
  <p class="text-sm text-gray-400 italic p-2">Demnächst verfügbar</p>
)}
