---
import ManagementReel from "./ManagementReel.vue";
---

<section class="mgmt-section">
  <div class="mgmt-inner">
    <ManagementReel client:load />
  </div>
</section>

<style>
  .mgmt-section {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: #fff;
    padding: 0.5rem 1.5rem 2rem;
  }

  .mgmt-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mgmt-eyebrow {
    display: inline-block;
    color: #1d4ed8;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
  }
</style>
