---
// src/layouts/LandingLayout.astro
import "../assets/app.css";
import Navbar from "../components/Navbar/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  // darkHero: Navbar startet transparent über dunklem Hero (Landingpages).
  // Für helle Inhaltsseiten (z. B. Impressum) auf false setzen — dann ist die
  // Navbar von Anfang an weiß und über weißem Hintergrund sichtbar.
  darkHero?: boolean;
}

const {
  title = "AI-driven Platform for Enterprises & Telcos | CreaLog",
  description,
  darkHero = true,
} = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body>
    <Navbar darkHero={darkHero} />
    <slot />
    <Footer />
  </body>
</html>
<style>
  html, body { margin: 0; width: 100%; height: 100%; }
</style>
