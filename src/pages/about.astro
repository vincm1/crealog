---
// Über-uns-Seite. Inhalte faktenbasiert von crealog.com (About CreaLog,
// Standort, Zertifizierungen, Philosophie). Eigene Seiten-Shell mit
// transparenter Navbar über dunklem Hero — analog zu den Landingpages.
import "../assets/app.css";
import Navbar from "../components/Navbar/Navbar.astro";
import Footer from "../components/Footer.astro";
import CtaBanner from "../components/Banners/CtaBanner.astro";

const stats = [
  { value: "30+", label: "Jahre intelligente Kommunikation" },
  { value: "30+", label: "Länder mit CreaLog-Lösungen" },
  { value: "3", label: "ISO-Zertifizierungen" },
  { value: "24/7", label: "Support & Betrieb" },
];

const principles = [
  {
    title: "Kunden- & Marktorientierung",
    text: "Wir richten unser Handeln konsequent an den Anforderungen unserer Kunden und der Märkte aus.",
  },
  {
    title: "Qualitätsbewusste Mitarbeitende",
    text: "Kompetente, engagierte Teams sind die Grundlage für die Qualität unserer Lösungen.",
  },
  {
    title: "Erfolg durch Exzellenz",
    text: "Wirtschaftlicher Erfolg entsteht aus technischer und organisatorischer Spitzenleistung.",
  },
  {
    title: "Kontinuierliche Verbesserung",
    text: "Wir hinterfragen und optimieren unsere Prozesse fortlaufend.",
  },
  {
    title: "Präventive Qualitätssicherung",
    text: "Fehler vermeiden statt korrigieren — Qualität wird vorausschauend gesichert.",
  },
  {
    title: "Partnerschaftliche Lieferanten",
    text: "Langfristige, faire Partnerschaften mit unseren Lieferanten schaffen gemeinsamen Mehrwert.",
  },
];

const certifications = [
  { code: "ISO 9001:2015", label: "Qualitätsmanagement" },
  { code: "ISO 14001:2015", label: "Umweltmanagement" },
  { code: "ISO/IEC 27001:2022", label: "Informationssicherheit" },
];

const customers = [
  "Deutsche Telekom",
  "Vodafone",
  "Swisscom",
  "A1 Telekom Austria",
  "Sunrise",
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta
      name="description"
      content="CreaLog entwickelt seit über 30 Jahren intelligente Kommunikationslösungen für Enterprises und Telco-Provider. Über uns, Werte, Zertifizierungen und Standort München."
    />
    <title>Über uns | CreaLog</title>
  </head>
  <body>
    <Navbar darkHero={true} />

    <main class="about">
      <!-- Hero -->
      <section class="about-hero">
        <div class="about-hero__inner">
          <span class="about-eyebrow about-eyebrow--light">Über uns</span>
          <h1 class="about-hero__title">
            30 Jahre intelligente Kommunikation
          </h1>
          <p class="about-hero__sub">
            CreaLog ist ein führender Anbieter von ICT-Carrier-Lösungen und
            cloud-nativen IMS Service-Delivery-Plattformen für
            Kommunikationsdienstleister und Unternehmen — von der
            Sprachautomatisierung bis zum unternehmenskritischen Netzbetrieb.
          </p>
        </div>
      </section>

      <!-- Stats -->
      <section class="about-stats">
        <div class="about-stats__grid">
          {
            stats.map((s) => (
              <div class="about-stat">
                <span class="about-stat__value">{s.value}</span>
                <span class="about-stat__label">{s.label}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Story -->
      <section class="about-block">
        <div class="about-block__grid">
          <div class="about-block__lead">
            <span class="about-eyebrow">Wer wir sind</span>
            <h2 class="about-h2">
              Zuverlässige Telekommunikationslösungen — seit 1996
            </h2>
          </div>
          <div class="about-block__body">
            <p>
              Seit der Gründung entwickelt CreaLog innovative und verlässliche
              Lösungen für die Telekommunikation — als mehrfach ausgezeichneter
              Anbieter für On-Premises-, Cloud- und SaaS-Betriebsmodelle.
            </p>
            <p>
              Zum Portfolio zählen Voice- und Chat-Bots, IVR- und
              Contact-Center-Systeme, net-centric Call Recording, Messaging
              (SMS/RCS/MMS/USSD), Notruf-Lösungen (NG112), Televoting sowie
              SIP-Application-Server und IMS-Technologien auf Basis einer
              cloud-nativen Service Delivery Platform.
            </p>
            <p>
              Unser Anspruch: Lösungen, die <strong>innovativ, erfolgreich und
              kundenzentriert</strong> sind — getragen von persönlicher
              Verantwortung vom ersten Kick-off bis zum Go-live und darüber
              hinaus.
            </p>
          </div>
        </div>
      </section>

      <!-- Mission / Philosophie -->
      <section class="about-block about-block--tint">
        <div class="about-block__grid">
          <div class="about-block__lead">
            <span class="about-eyebrow">Unsere Philosophie</span>
            <h2 class="about-h2">
              Erfolg durch gemeinsames Qualitäts-, Umwelt- und
              Sicherheitsbewusstsein
            </h2>
            <p class="about-lead__text">
              Unser Handeln folgt sechs Grundprinzipien, die Qualität und
              Verantwortung in jeden Schritt tragen.
            </p>
          </div>
          <div class="about-principles">
            {
              principles.map((p, i) => (
                <div class="about-principle">
                  <span class="about-principle__num">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <h3 class="about-principle__title">{p.title}</h3>
                  <p class="about-principle__text">{p.text}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Was uns auszeichnet -->
      <section class="about-block">
        <div class="about-highlight">
          <span class="about-eyebrow about-eyebrow--light">Was uns auszeichnet</span>
          <p class="about-highlight__quote">
            „Unser Team bietet Kunden in mehr als 30 Ländern einen ganz
            besonderen Service: Es übernimmt persönliche Verantwortung — vom
            ersten Kick-off bis zum Go-live der Lösung, und darüber hinaus."
          </p>
        </div>
      </section>

      <!-- Zertifizierungen + Standort -->
      <section class="about-block about-block--tint">
        <div class="about-block__grid">
          <div class="about-block__lead">
            <span class="about-eyebrow">Zertifizierungen & Standort</span>
            <h2 class="about-h2">Geprüfte Qualität, klarer Sitz.</h2>
            <p class="about-lead__text">
              CreaLog arbeitet nach international anerkannten Normen für
              Qualität, Umwelt und Informationssicherheit.
            </p>
          </div>
          <div class="about-block__body">
            <div class="about-certs">
              {
                certifications.map((c) => (
                  <div class="about-cert">
                    <span class="about-cert__code">{c.code}</span>
                    <span class="about-cert__label">{c.label}</span>
                  </div>
                ))
              }
            </div>

            <address class="about-address">
              <strong>CreaLog Software-Entwicklung und Beratung GmbH</strong>
              Frankfurter Ring 211<br />
              80807 München, Deutschland<br />
              <a href="tel:+498932465600">Tel. +49 89 324656-0</a> ·
              <a href="tel:+4989324656010">24/7-Hotline +49 89 324656-10</a>
            </address>
          </div>
        </div>
      </section>

      <!-- Kunden -->
      <section class="about-block">
        <div class="about-customers">
          <span class="about-eyebrow">Vertrauen führender Anbieter</span>
          <h2 class="about-h2 about-h2--center">
            Im Einsatz bei Carriern in ganz Europa und Afrika
          </h2>
          <ul class="about-customers__list">
            {customers.map((c) => <li class="about-customer">{c}</li>)}
          </ul>
        </div>
      </section>

      <CtaBanner
        title="Lernen Sie CreaLog kennen"
        subline="Sprechen Sie mit unseren Experten über Ihre Anforderungen in der Kundenkommunikation."
        primaryText="Kontakt aufnehmen"
        primaryHref="/kontakt"
      />
    </main>

    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .about {
    font-family: "Poppins", Calibri, sans-serif;
    color: #0f1e30;
    background: #fff;
  }

  /* ── shared type ── */
  .about-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(0 64 129);
    margin-bottom: 1rem;
  }
  .about-eyebrow--light {
    color: rgba(255, 255, 255, 0.7);
  }

  .about-h2 {
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }
  .about-h2--center {
    text-align: center;
  }

  /* ── hero ── */
  .about-hero {
    position: relative;
    background:
      radial-gradient(
        120% 120% at 80% 0%,
        rgba(29, 78, 216, 0.55) 0%,
        transparent 55%
      ),
      linear-gradient(160deg, #0a1628 0%, #0f2440 55%, #10346b 100%);
    padding: clamp(9rem, 14vw, 12rem) 1.5rem clamp(4rem, 8vw, 6rem);
    overflow: hidden;
  }
  .about-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.06) 1px,
      transparent 1px
    );
    background-size: 24px 24px;
    pointer-events: none;
  }
  .about-hero__inner {
    position: relative;
    max-width: 80rem;
    margin: 0 auto;
  }
  .about-hero__title {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.04;
    color: #fff;
    margin: 0;
    max-width: 16ch;
  }
  .about-hero__sub {
    margin: 1.5rem 0 0;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.78);
    max-width: 60ch;
  }

  /* ── stats ── */
  .about-stats {
    background: #0a1628;
    padding: 0 1.5rem;
  }
  .about-stats__grid {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    overflow: hidden;
    transform: translateY(-50%);
    box-shadow: 0 30px 60px -30px rgba(10, 22, 40, 0.5);
  }
  @media (min-width: 768px) {
    .about-stats__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .about-stat {
    background: #0f2440;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .about-stat__value {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 1;
  }
  .about-stat__label {
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.62);
  }

  /* ── content blocks ── */
  .about-block {
    padding: clamp(3rem, 7vw, 6rem) 1.5rem;
  }
  .about-block--tint {
    background: #f1f5fb;
    border-top: 1px solid #dce5f0;
    border-bottom: 1px solid #dce5f0;
  }
  .about-block__grid {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .about-block__grid {
      grid-template-columns: 0.85fr 1.15fr;
      gap: 4rem;
      align-items: start;
    }
  }
  .about-lead__text {
    margin: 1rem 0 0;
    font-size: 1rem;
    line-height: 1.7;
    color: #4b5563;
  }
  .about-block__body p {
    margin: 0 0 1.1rem;
    font-size: 1.02rem;
    line-height: 1.8;
    color: #374151;
  }
  .about-block__body p:last-child {
    margin-bottom: 0;
  }
  .about-block__body strong {
    color: #0f1e30;
    font-weight: 700;
  }

  /* ── principles ── */
  .about-principles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .about-principles {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .about-principle {
    background: #fff;
    border: 1px solid #dce5f0;
    border-radius: 16px;
    padding: 1.5rem;
  }
  .about-principle__num {
    font-size: 0.8rem;
    font-weight: 700;
    color: rgb(0 64 129);
    letter-spacing: 0.1em;
  }
  .about-principle__title {
    margin: 0.5rem 0 0.4rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f1e30;
  }
  .about-principle__text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #6b7280;
  }

  /* ── highlight quote ── */
  .about-highlight {
    max-width: 80rem;
    margin: 0 auto;
    background: linear-gradient(160deg, #10346b 0%, #1d4ed8 100%);
    border-radius: 32px;
    padding: clamp(2.5rem, 6vw, 4.5rem);
    text-align: center;
  }
  .about-highlight__quote {
    margin: 0.5rem auto 0;
    max-width: 46ch;
    font-size: clamp(1.3rem, 2.6vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.35;
    color: #fff;
  }

  /* ── certs + address ── */
  .about-certs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 560px) {
    .about-certs {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .about-cert {
    background: #fff;
    border: 1px solid #dce5f0;
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .about-cert__code {
    font-size: 0.95rem;
    font-weight: 800;
    color: rgb(0 64 129);
    letter-spacing: -0.01em;
  }
  .about-cert__label {
    font-size: 0.8rem;
    color: #6b7280;
  }
  .about-address {
    font-style: normal;
    font-size: 0.95rem;
    line-height: 1.9;
    color: #4b5563;
  }
  .about-address strong {
    display: block;
    color: #0f1e30;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .about-address a {
    color: rgb(0 64 129);
    text-decoration: none;
  }
  .about-address a:hover {
    text-decoration: underline;
  }

  /* ── customers ── */
  .about-customers {
    max-width: 80rem;
    margin: 0 auto;
    text-align: center;
  }
  .about-customers__list {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  .about-customer {
    background: #f1f5fb;
    border: 1px solid #dce5f0;
    border-radius: 9999px;
    padding: 0.6rem 1.35rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #374151;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      scroll-behavior: auto;
    }
  }
</style>
