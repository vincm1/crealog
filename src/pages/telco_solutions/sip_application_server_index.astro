---
import "../../assets/app.css";
import Navbar from "../../components/Navbar/Navbar.astro";
import Footer from "../../components/Footer.astro";

// Inhalte: crealog.com/de/plattform-technologie/sip-applikation-server/

const characteristics = [
  "IMS-konform",
  "SIP-basiert",
  "netzwerkunabhängig",
  "geräteunabhängig",
  "telco-erprobt",
  "SIP TLS · SRTP",
];

const liveRows = [
  { name: "SIP Registrar / Proxy", load: 44 },
  { name: "Number Translation", load: 58 },
  { name: "Voice VPN", load: 36 },
  { name: "Media / IVR", load: 22 },
];

// „NG-IN / Number Translation" — Kernfunktionen
const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/></svg>`,
    title: "Zukunftssichere Technologie",
    desc: "SIP-basierte Lösung mit voller Interoperabilität und nahtlosem IMS-Netzübergang.",
    tags: ["SIP", "IMS"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
    title: "Netzwerk- & geräteunabhängig",
    desc: "Verarbeitet Verkehr aus IP- und leitungsvermittelten Netzen — unabhängig vom Endgerät.",
    tags: ["IP", "Circuit-switched"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/></svg>`,
    title: "Hohe Kapazität",
    desc: "Telco-erprobte Plattform mit integriertem Überlastungsschutz für hohe Lasten.",
    tags: ["Überlastschutz", "Skalierbar"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>`,
    title: "Hochgradig anpassbar",
    desc: "Flexible Anpassung an individuelle Kundenanforderungen und freie Skalierung.",
    tags: ["Konfigurierbar", "Modular"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.353 5.988 5.988 0 01-2.031-.353c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.353 5.989 5.989 0 01-2.031-.353c-.483-.174-.711-.703-.59-1.202L5.25 4.971z"/></svg>`,
    title: "Garantierte Rechtskonformität",
    desc: "Erfüllt geltende gesetzliche und regulatorische Anforderungen zuverlässig.",
    tags: ["Compliance", "Audit-fähig"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>`,
    title: "Kundenselbstverwaltung",
    desc: "Eigenständige Verwaltung über eine benutzerfreundliche, intuitive GUI.",
    tags: ["Self-Service", "GUI"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
    title: "Effizientes Routing",
    desc: "Schnelle und einfache Bereitstellung von Routing-Regeln ohne Umwege.",
    tags: ["Provisioning", "Realtime"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>`,
    title: "Flexible Betriebsoptionen",
    desc: "Eigenständiger Betrieb oder Kombination mit gehosteten Funktionen.",
    tags: ["Standalone", "Hosted"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
    title: "Statistiken für Kunden",
    desc: "Detaillierte Nutzungsinformationen und Auswertungen pro Kunde.",
    tags: ["Reporting", "Insights"],
  },
];

// „Voice VPN" — Vorteile als Checkliste
const vpn = [
  "Ein- und ausgehende SIP-Anrufe",
  "Anrufumleitung, -verweigerung, Weiterleitung & Übertragung",
  "SIP-Registrar- & Proxy-Server mit Authentifizierung",
  "Konfigurierbare SIP-Portbereiche & NAT-Translation",
  "Verbesserte Sicherheit mit SIP TLS & SRTP",
];

// „Medien & Sprachverarbeitung" — Media-Fähigkeiten
const media = [
  "Audioansagen",
  "Bridging",
  "Mischen",
  "Konferenzschaltung",
  "Rauschunterdrückung",
  "Spracherkennung (ASR)",
  "Sprachsynthese (TTS)",
  "DTMF-Erkennung",
  "DTMF-Generierung",
];

// „Fakten & Funktionen"
const specs = [
  { label: "Standards", value: "W3C · IETF · ITU · ANSI" },
  { label: "Protokolle", value: "SIP · IMS · SIP-T" },
  { label: "Sicherheit", value: "SIP TLS · SRTP" },
  { label: "Medien", value: "ASR · TTS · DTMF · Konferenz" },
  { label: "Netze", value: "IP · leitungsvermittelt · PSTN/SIP-Gateway" },
  { label: "Dienste", value: "NG-IN Number Translation · Voice VPN" },
  { label: "Verwaltung", value: "Self-Service-GUI · Kundenstatistiken" },
  { label: "Betrieb", value: "Standalone oder gehostet" },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>SIP Applikations-Server | CreaLog Telco Solutions</title>
    <meta
      name="description"
      content="Standardkonformer IMS SIP Applikations-Server von CreaLog — SIP-basiert, netzwerk- und geräteunabhängig, telco-erprobt. Für NG-IN Number Translation und Voice VPN."
    />
  </head>
  <body class="ix-page">
    <Navbar />

    <!-- ── Hero ──────────────────────────────────────────────────────────── -->
    <section class="ix-hero">
      <div class="ix-hero__aurora" aria-hidden="true"></div>
      <div class="ix-container">
        <div class="ix-hero__inner">
          <div class="ix-hero__left">
            <nav class="ix-breadcrumb">
              <a href="/">CreaLog</a>
              <span>›</span>
              <a href="/telco-solutions">Telco Solutions</a>
              <span>›</span>
              <span>SIP Applikations-Server</span>
            </nav>

            <div class="ix-eyebrow-wrap">
              <div class="ix-eyebrow-dash"></div>
              <span class="ix-eyebrow">Plattform-Technologie</span>
            </div>

            <h1 class="ix-hero__h1">
              SIP Applikations-<br />
              <span class="ix-hero__accent">Server</span>
            </h1>

            <p class="ix-hero__sub">
              Der standardkonforme, IMS-fähige SIP Applikations-Server von
              CreaLog ist die Basis für Number-Translation-Dienste (NG-IN) und
              Voice VPN — netzwerk- und geräteunabhängig, telco-erprobt und
              hochgradig anpassbar.
            </p>

            <div class="ix-chips">
              {characteristics.map((c) => <span class="ix-chip">{c}</span>)}
            </div>

            <div class="ix-hero__ctas">
              <a href="/kontakt" class="ix-btn ix-btn--primary">
                Demo vereinbaren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </a>
              <a href="/kontakt" class="ix-btn ix-btn--outline">
                Datenblatt anfordern
              </a>
            </div>
          </div>

          <!-- Right: live status card -->
          <div class="ix-hero__right" aria-hidden="true">
            <div class="ix-preview">
              <div class="ix-preview__bar"><i></i><i></i><i></i></div>
              <div class="ix-preview__body">
                <div class="ix-preview__label">SIP AS — Live Status</div>
                {liveRows.map((row) => (
                  <div class="ix-row">
                    <span class="ix-row__dot" />
                    <span class="ix-row__name">{row.name}</span>
                    <div class="ix-row__bar">
                      <div class="ix-row__fill" style={`width:${row.load}%`} />
                    </div>
                    <span class="ix-row__pct">{row.load}%</span>
                  </div>
                ))}
                <div class="ix-preview__footer">
                  <span class="ix-live"><span class="ix-live__dot" />Live</span>
                  <span>IMS-konform · SIP TLS</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── NG-IN / Number Translation ────────────────────────────────────── -->
    <section class="ix-section ix-features">
      <div class="ix-container">
        <div class="ix-sec-head">
          <div class="ix-eyebrow-wrap">
            <div class="ix-eyebrow-dash"></div>
            <span class="ix-eyebrow">NG-IN / Number Translation</span>
          </div>
          <div class="ix-sec-head__row">
            <h2 class="ix-sec-title">
              Intelligente<br />
              <span class="ix-title-accent">Number-Translation-Dienste</span>
            </h2>
            <p class="ix-sec-sub">
              Neun Stärken, die den SIP Applikations-Server für Carrier
              unverzichtbar machen.
            </p>
          </div>
        </div>
        <div class="ix-feat-grid reveal-section">
          {features.map((f) => (
            <div class="ix-feat-card reveal">
              <span class="ix-feat-card__bar" aria-hidden="true" />
              <div class="ix-feat-card__icon" set:html={f.icon} />
              <h3 class="ix-feat-card__title">{f.title}</h3>
              <p class="ix-feat-card__desc">{f.desc}</p>
              <div class="ix-feat-card__tags">
                {f.tags.map((t) => <span class="ix-tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Voice VPN ─────────────────────────────────────────────────────── -->
    <section class="ix-section ix-vpn">
      <div class="ix-container">
        <div class="ix-vpn__inner reveal-section">
          <div class="ix-vpn__left reveal">
            <div class="ix-eyebrow-wrap">
              <div class="ix-eyebrow-dash"></div>
              <span class="ix-eyebrow">Voice VPN</span>
            </div>
            <h2 class="ix-sec-title ix-vpn__title">
              Sichere virtuelle<br />
              <span class="ix-title-accent">Sprachnetze</span>
            </h2>
            <p class="ix-sec-sub ix-vpn__sub">
              Vollwertige SIP-Anrufsteuerung mit Registrar, Proxy und
              Authentifizierung — abgesichert über SIP TLS und SRTP.
            </p>
          </div>
          <div class="ix-vpn__card reveal">
            <ul class="ix-check-list">
              {vpn.map((item) => (
                <li class="ix-check-item">
                  <svg class="ix-check-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Medien & Sprachverarbeitung ───────────────────────────────────── -->
    <section class="ix-section ix-channels">
      <div class="ix-container">
        <div class="ix-channels__inner reveal-section">
          <div class="ix-channels__head reveal">
            <div class="ix-eyebrow-wrap">
              <div class="ix-eyebrow-dash"></div>
              <span class="ix-eyebrow">Medienverarbeitung</span>
            </div>
            <h2 class="ix-sec-title">
              Integrierte<br />
              <span class="ix-title-accent">Sprach- & Medienfunktionen</span>
            </h2>
            <p class="ix-sec-sub ix-channels__sub">
              Von Audioansagen über Konferenzen bis ASR, TTS und
              DTMF — alles direkt in der Plattform.
            </p>
          </div>
          <div class="ix-channels__cloud reveal">
            {media.map((m) => <span class="ix-channel">{m}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Standards band ────────────────────────────────────────────────── -->
    <section class="ix-section ix-band-sec">
      <div class="ix-container">
        <div class="ix-band reveal-section">
          <div class="ix-band__glow" aria-hidden="true"></div>
          <div class="ix-band__icon reveal" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
          </div>
          <div class="ix-band__text">
            <span class="ix-band__eyebrow reveal">Standardkonform</span>
            <h2 class="ix-band__title reveal">
              Unterstützt alle wichtigen Standards
            </h2>
            <p class="ix-band__desc reveal">
              Der SIP Applikations-Server unterstützt alle wichtigen
              <strong>W3C-, IETF-, ITU- und ANSI-Standards</strong> — für
              maximale Interoperabilität und einen nahtlosen IMS-Netzübergang.
            </p>
            <div class="ix-band__tags reveal">
              <span class="ix-band__tag">W3C</span>
              <span class="ix-band__tag">IETF</span>
              <span class="ix-band__tag">ITU</span>
              <span class="ix-band__tag">ANSI</span>
              <span class="ix-band__tag">SIP TLS</span>
              <span class="ix-band__tag">SRTP</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Specs / Fakten & Funktionen ───────────────────────────────────── -->
    <section class="ix-section ix-specs">
      <div class="ix-container">
        <div class="ix-specs__inner">
          <div class="ix-specs__left reveal-section">
            <div class="ix-eyebrow-wrap reveal">
              <div class="ix-eyebrow-dash"></div>
              <span class="ix-eyebrow">Fakten & Funktionen</span>
            </div>
            <h2 class="ix-sec-title ix-specs__title reveal">
              IMS-konform,<br /><span class="ix-title-accent">SIP-nativ</span>
            </h2>
            <p class="ix-sec-sub ix-specs__sub reveal">
              Eine telco-erprobte Plattform, gebaut für Interoperabilität,
              Sicherheit und hohe Lasten in Carrier-Netzen.
            </p>
            <div class="ix-specs__badges reveal">
              <span class="ix-sbadge">IMS-konform</span>
              <span class="ix-sbadge">SIP TLS · SRTP</span>
              <span class="ix-sbadge">W3C · IETF</span>
              <span class="ix-sbadge">telco-erprobt</span>
            </div>
          </div>
          <div class="ix-specs__right reveal-section">
            {specs.map((s) => (
              <div class="ix-spec-row reveal">
                <span class="ix-spec-row__label">{s.label}</span>
                <span class="ix-spec-row__value">{s.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────────────────────────── -->
    <section class="ix-section ix-cta">
      <div class="ix-container">
        <div class="ix-cta__inner reveal-section">
          <div class="ix-cta__glow" aria-hidden="true"></div>
          <div class="ix-eyebrow-wrap reveal" style="justify-content:center;">
            <div class="ix-eyebrow-dash" style="background:#7dd3fc;"></div>
            <span class="ix-eyebrow" style="color:#7dd3fc;">Nächster Schritt</span>
          </div>
          <h2 class="ix-cta__title reveal">
            Bereit für standardkonforme SIP-Dienste?
          </h2>
          <p class="ix-cta__sub reveal">
            Sprechen Sie mit einem unserer Telco-Experten oder fordern Sie direkt
            das technische Datenblatt zum SIP Applikations-Server an.
          </p>
          <div class="ix-cta__btns reveal">
            <a href="/kontakt" class="ix-btn ix-btn--light">Demo vereinbaren →</a>
            <a href="/kontakt" class="ix-btn ix-btn--ghost">Datenblatt anfordern</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap");

  .ix-page {
    font-family: "Plus Jakarta Sans", sans-serif;
    margin: 0;
    background: #fff;
  }
  html, body { margin: 0; width: 100%; }

  .ix-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 1024px) { .ix-container { padding: 0 2.5rem; } }

  /* ── sections ── */
  .ix-section { padding: 5rem 0; }
  .ix-features { background: #fff; }
  .ix-vpn { background: #f8faff; border-top: 1px solid #e6e8ec; border-bottom: 1px solid #e6e8ec; }
