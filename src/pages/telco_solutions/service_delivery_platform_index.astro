    color: rgba(255, 255, 255, 0.58);
    margin: 0 auto 2rem;
    max-width: 36ch;
  }
  .cta-btns {
    position: relative;
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Scroll reveal ── */
  .reveal-section.ready .reveal {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-section.ready .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-section.ready .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const sections =
    document.querySelectorAll<HTMLElement>(".reveal-section");
  const reduce = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  sections.forEach((section) => {
    section.classList.add("ready");
    const items = section.querySelectorAll<HTMLElement>(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement;
            const idx = Array.from(items).indexOf(el);
            el.style.transitionDelay = reduce ? "0ms" : `${idx * 55}ms`;
            el.classList.add("visible");
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    items.forEach((el) => io.observe(el));
  });
</script>
