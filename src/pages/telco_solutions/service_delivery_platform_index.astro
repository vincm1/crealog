---
import "../../assets/app.css";
import Navbar from "../../components/Navbar/Navbar.astro";
import Footer from "../../components/Footer.astro";

const characteristics = [
  "Made in Europe",
  "telco-grade",
  "cloud-native",
  "multitenant",
  "geo-redundant",
  "AI-enabled",
  "MCP-ready",
];

const liveRows = [
  { name: "NTS & VPN", load: 38 },
  { name: "Call Completion", load: 61 },
  { name: "Voice & Chat Bots", load: 47 },
  { name: "NG112 Emergency", load: 12 },
];

const vorteile = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 1.046a1 1 0 01.7 1.215L10.06 9H16a1 1 0 01.78 1.625l-9 11A1 1 0 016 21l1.94-7H2a1 1 0 01-.78-1.625l9-11a1 1 0 01.08-.329z"/></svg>`,
    title: "Schnellere Service-Einführung",
    desc: "Neue Kommunikations- und Mehrwertdienste schneller bereitstellen und am Markt platzieren.",
    tags: ["Time-to-Market", "Visual Builder"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>`,
    title: "Flexible Anpassung",
    desc: "Dienste flexibel an individuelle Anforderungen und Geschäftsmodelle anpassen.",
    tags: ["Konfigurierbar", "Modular"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>`,
    title: "Nahtlose Integration",
    desc: "Nahtlose Integration in bestehende und zukünftige Netzwerkumgebungen.",
    tags: ["IMS / VoLTE", "5G-ready"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>`,
    title: "Legacy-Migration",
    desc: "Sichere Migration von Legacy-Umgebungen ohne Bruch im laufenden Betrieb.",
    tags: ["TDM / SS7", "Schrittweise"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/></svg>`,
    title: "Telco-grade Betrieb",
    desc: "Telco-grade Verfügbarkeit und geo-redundanter Betrieb für maximale Ausfallsicherheit.",
    tags: ["Geo-redundant", "Multitenant"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Governance & Souveränität",
    desc: "Governance, Compliance und digitale Souveränität. Made in Europe.",
    tags: ["Compliance", "Souveränität"],
  },
];

const apps = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5l-3.9 19.5m-2.1-19.5l-3.9 19.5"/></svg>`,
    name: "Nummernumsetzung (NTS) & VPN",
    desc: "Nummernumsetzungsdienste und virtuelle private Netze.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>`,
    name: "Call Completion",
    desc: "Zuverlässige Zustellung und Vervollständigung von Anrufen.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/></svg>`,
    name: "Voicebots, Chatbots & KI-Agenten",
    desc: "Automatisierte Dialoge über Sprache, Chat und KI.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
    name: "Contact Center",
    desc: "Omnichannel-Contact-Center-Funktionen aus einer Plattform.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>`,
    name: "NG112-Notfalldienste",
    desc: "Next-Generation-Notruf nach NG112-Standard.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>`,
    name: "Recording",
    desc: "Rechtssichere Gesprächs- und Sitzungsaufzeichnung.",
  },
];

const channels = [
  "Telefonie",
  "HD Voice",
  "RTT",
  "E-Mail-Bots",
  "Microsoft Teams",
  "RCS / SMS",
  "Messenger",
  "Web & App",
  "WebRTC",
  "Video",
];

const betriebsmodelle = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/></svg>`,
    name: "Cloud-nativ / agnostisch",
    desc: "Containerisiert und cloud-agnostisch in jeder Umgebung betreibbar.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>`,
    name: "On-Premises",
    desc: "Vollständiger Betrieb im eigenen Rechenzentrum.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>`,
    name: "Private Cloud",
    desc: "Dedizierte, isolierte Cloud-Umgebung.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>`,
    name: "Managed Service",
    desc: "Betrieb und Wartung als Managed Service durch CreaLog.",
  },
];

const specs = [
  { label: "Standards", value: "IMS · VoLTE · 5G-ready" },
  { label: "Legacy-Support", value: "TDM · SS7" },
  { label: "Echtzeit-Medien", value: "WebRTC · RTT · HD Voice" },
  { label: "Schnittstellen", value: "Third-Party Web Services · REST APIs" },
  { label: "KI-Integration", value: "Model Context Protocol (MCP)" },
  { label: "Betrieb", value: "telco-grade · geo-redundant · multitenant" },
  { label: "Bereitstellung", value: "Cloud-nativ · On-Prem · Private Cloud · Managed" },
  { label: "Herkunft", value: "Made in Europe" },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Service Delivery Plattform | CreaLog Telco Solutions</title>
    <meta
      name="description"
      content="Die CreaLog Service Delivery Plattform (SDP) - telco-grade, cloud-native und Made in Europe. Neue Kommunikations- und Mehrwertdienste schneller bereitstellen."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="sdp-page">
    <Navbar />

    <!-- Hero -->
    <section class="hero">
      <div class="hero__glow" aria-hidden="true"></div>
      <div class="hero__grid" aria-hidden="true"></div>
      <div class="container">
        <div class="hero__inner">
          <div class="hero__left">
            <nav class="breadcrumb" aria-label="Breadcrumb">
              <a href="/">CreaLog</a>
              <span aria-hidden="true">/</span>
              <a href="/telco-solutions">Telco Solutions</a>
              <span aria-hidden="true">/</span>
              <span>Service Delivery Plattform</span>
            </nav>

            <h1 class="hero__h1">
              Service Delivery<br />
              <em class="hero__accent">Plattform</em>
            </h1>

            <p class="hero__sub">
              Neue Telco-Services schneller einführen, Bestandsnetze
              kontrolliert modernisieren und Enterprise Services wirtschaftlich
              skalieren.
            </p>

            <div class="hero__ctas">
              <a href="/kontakt" class="btn btn--primary">
                Demo vereinbaren
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
                </svg>
              </a>
              <a href="/kontakt" class="btn btn--outline">Datenblatt anfordern</a>
            </div>
          </div>

          <div class="hero__right" aria-hidden="true">
            <div class="sdp-card">
              <div class="sdp-card__header">
                <span class="sdp-card__label">SDP Live Status</span>
                <span class="sdp-card__live">
                  <span class="live-dot"></span>Live
                </span>
              </div>
              <div class="sdp-card__body">
                {
                  liveRows.map((row) => (
                    <div class="sdp-row">
                      <span class="sdp-row__name">{row.name}</span>
                      <div class="sdp-row__track">
                        <div
                          class="sdp-row__fill"
                          style={`width:${row.load}%`}
                        />
                      </div>
                      <span class="sdp-row__pct">{row.load}%</span>
                    </div>
                  ))
                }
              </div>
              <div class="sdp-card__footer">telco-grade · geo-redundant</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Characteristics strip -->
    <div class="strip">
      <div class="container">
        <div class="strip__inner">
          {characteristics.map((c) => <span class="strip__chip">{c}</span>)}
        </div>
      </div>
    </div>

    <!-- Features -->
    <section class="section features">
      <div class="container">
        <div class="features__head">
          <span class="eyebrow">Kernanforderungen</span>
          <h2 class="section-title">
            Entwickelt für die<br /><span class="accent"
              >Anforderungen von CSPs</span
            >
          </h2>
          <p class="section-sub">
            Sechs Stärken, die Carrier und Communication Service Provider
            wirklich brauchen.
          </p>
        </div>

        <!-- Top: 2 wide feature cards -->
        <div class="feat-top">
          {
            vorteile.slice(0, 2).map((f) => (
              <div class="feat-wide">
                <div class="feat-icon" set:html={f.icon} />
                <div class="feat-wide__body">
                  <h3 class="feat-wide__title">{f.title}</h3>
                  <p class="feat-wide__desc">{f.desc}</p>
                  <div class="feat-tags">
                    {f.tags.map((t) => (
                      <span class="feat-tag">{t}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Bottom: 4 compact cards -->
        <div class="feat-grid">
          {
            vorteile.slice(2).map((f) => (
              <div class="feat-card">
                <div class="feat-icon feat-icon--sm" set:html={f.icon} />
                <h3 class="feat-card__title">{f.title}</h3>
                <p class="feat-card__desc">{f.desc}</p>
                <div class="feat-tags">
                  {f.tags.map((t) => (
                    <span class="feat-tag">{t}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Apps -->
    <section class="section apps">
      <div class="container">
        <div class="apps__head">
          <div>
            <h2 class="section-title">
              Eine Plattform für <span class="accent">alle Telco-Services</span>
            </h2>
            <p class="section-sub">
              Bewährte Dienste. Sofort einsatzbereit, beliebig kombinierbar.
            </p>
          </div>
        </div>
        <div class="app-list">
          {
            apps.map((a) => (
              <div class="app-item">
                <div class="app-item__icon" set:html={a.icon} />
                <div class="app-item__text">
                  <h3 class="app-item__name">{a.name}</h3>
                  <p class="app-item__desc">{a.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Omnichannel -->
    <section class="section channels">
      <div class="container">
        <span class="eyebrow">Omnichannel</span>
        <h2 class="section-title">
          Architektur für <span class="accent">alle Kanäle</span>
        </h2>
        <p class="section-sub channels__sub">
          Eine einheitliche Experience von klassischer Telefonie bis WebRTC und
          Video.
        </p>
        <div class="channel-cloud">
          {channels.map((c) => <span class="channel-chip">{c}</span>)}
        </div>
      </div>
    </section>

    <!-- AI band -->
    <section class="section ai-band">
      <div class="container">
        <div class="ai-inner">
          <div class="ai-inner__glow" aria-hidden="true"></div>
          <div class="ai-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5M4.5 15.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"
              ></path></svg
            >
          </div>
          <div class="ai-text">
            <span class="ai-label">AI-ready</span>
            <h2 class="ai-title">Mit zukunftssicherer Standardisierung</h2>
            <p class="ai-desc">
              Über das <strong>Model Context Protocol (MCP)</strong> ermöglicht
              die SDP sichere, governance-konforme KI-gesteuerte
              Service-Interaktionen - standardisiert und zukunftssicher.
            </p>
            <div class="ai-tags">
              <span>MCP-ready</span>
              <span>AI-enabled</span>
              <span>Governance-konform</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Betriebsmodelle -->
    <section class="section deploy">
      <div class="container">
        <h2 class="section-title">
          Ihr Betriebsmodell,<br /><span class="accent">Ihre Entscheidung</span>
        </h2>
        <p class="section-sub deploy__sub">
          Die Plattform passt sich an Sicherheitsanforderungen und
          Compliance-Vorgaben an - nicht umgekehrt.
        </p>
        <div class="deploy-grid">
          {
            betriebsmodelle.map((d, i) => (
              <div class="deploy-item">
                <span class="deploy-item__num">0{i + 1}</span>
                <div class="deploy-item__icon" set:html={d.icon} />
                <h3 class="deploy-item__name">{d.name}</h3>
                <p class="deploy-item__desc">{d.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Specs -->
    <section class="section specs-section">
      <div class="container">
        <div class="specs-inner">
          <div class="specs-left reveal-section">
            <h2 class="section-title reveal">
              Telco-grade,<br /><span class="accent">cloud-native</span>
            </h2>
            <p class="section-sub reveal">
              Entwickelt für nationale Telekommunikationsnetze - multitenant,
              geo-redundant und für Lastspitzen gebaut.
            </p>
            <div class="spec-badges reveal">
              <span>telco-grade</span>
              <span>cloud-native</span>
              <span>MCP-ready</span>
              <span>Made in Europe</span>
            </div>
          </div>
          <div class="specs-right reveal-section">
            <div class="spec-grid">
              {
                specs.map((s) => (
                  <div class="spec-card reveal">
                    <span class="spec-card__label">{s.label}</span>
                    <span class="spec-card__value">{s.value}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section cta-section">
      <div class="container">
        <div class="cta-inner reveal-section">
          <div class="cta-inner__glow" aria-hidden="true"></div>
          <h2 class="cta-title reveal">Bereit, die SDP einzusetzen?</h2>
          <p class="cta-sub reveal">
            Fordern Sie das technische Datenblatt an oder sprechen Sie direkt
            mit unseren Telco-Experten.
          </p>
