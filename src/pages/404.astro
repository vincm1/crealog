---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="min-h-screen flex items-center justify-center bg-base-100 px-6">
    <div class="text-center max-w-lg">
      <p
        class="text-8xl font-extrabold text-primary opacity-10 select-none leading-none mb-2"
      >
        404
      </p>
      <h1 class="text-3xl font-bold text-base-content mt-[-2rem] mb-4">
        Seite nicht gefunden
      </h1>
      <p class="text-base-content/60 mb-8">
        Die gesuchte Seite existiert nicht oder wurde verschoben.
      </p>
      <a href="/" class="btn btn-primary px-8">
        Zurück zur Startseite

        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-6 h-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
        </svg>
      </a>
    </div>
  </main>
</Layout>
