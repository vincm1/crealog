// CreaLog Summit 2026 — dedizierte Anmeldeseite.
// Enthält das vollständige, von Brevo generierte HTML-Formular (kein iframe).
// Brevos CSS liegt global im <head>, die Brevo-Scripts sind `is:inline`, damit
// Astro sie unverändert 1:1 ausliefert. Läuft rein clientseitig (AJAX-POST an
// sibforms.com) — kein Server/Adapter nötig, kompatibel mit output: "static".
import "../assets/app.css";
import Navbar from "../components/Navbar/Navbar.astro";
import Footer from "../components/Footer.astro";

// Signatur der Seite: eine "Voice-Waveform" aus vertikalen Balken, die um eine
// Mittellinie spiegeln — Stimme sichtbar gemacht. Deterministisch berechnet
// (keine Zufallswerte), damit der Build reproduzierbar bleibt.
const wave = (count) =>
  Array.from({ length: count }, (_, i) => {
    const raw = Math.abs(
      Math.sin(i * 0.7) * 0.55 +
        Math.sin(i * 0.19 + 2.1) * 0.35 +
        Math.sin(i * 1.3) * 0.1,
    );
    const env = 0.1 + 0.9 * Math.min(1, raw); // 0.1 – 1.0
    const h = Math.round(8 + env * 92); // Höhe 8 – 100 %
    const dur = (0.9 + ((i * 13) % 9) / 10).toFixed(2); // 0.9 – 1.7 s
    const delay = (-(((i * 17) % 23) / 23) * 1.6).toFixed(2);
    const light = Math.round(30 + env * 30); // dunkel (kurz) → hell (hoch)
    const color = `hsl(213 80% ${light}%)`;
    return { h, dur, delay, color };
  });
const regWave = wave(40);
