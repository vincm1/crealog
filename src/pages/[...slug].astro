---
import { useStoryblokApi } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import SolutionSubPage from "../layouts/SolutionSubPage.astro";

export async function getStaticPaths() {
  const storyblokApi = useStoryblokApi();
  const stories = await storyblokApi.getAll("cdn/stories", {
    version: "published",
  });

  // Slugs mit eigener Route auslassen (index.astro -> "home", komponenten.astro),
  // damit keine doppelten Routen entstehen.
  const reserved = new Set(["home", "komponenten"]);

  return stories
    .filter((story: any) => !reserved.has(story.full_slug))
    .map((story: any) => ({
      params: { slug: story.full_slug },
      props: { story },
    }));
}

const { story } = Astro.props;
---

<SolutionSubPage>
  <StoryblokComponent blok={story.content} />
</SolutionSubPage>
