---
import { useStoryblokApi, getPayload } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import SolutionSubPage from "../layouts/SolutionSubPage.astro";

const isDraft = import.meta.env.DEV || import.meta.env.STORYBLOK_PREVIEW;

export async function getStaticPaths() {
  const storyblokApi = useStoryblokApi();
  const { data } = await storyblokApi.get("cdn/stories", {
    version: (import.meta.env.DEV || import.meta.env.STORYBLOK_PREVIEW) ? "draft" : "published",
    excluding_slugs: "home",
    per_page: 100,
  });
  return data.stories
    .filter((story: any) => !story.is_folder)
    .map((story: any) => ({
      params: { slug: story.full_slug },
      props: { story },
    }));
}

let { story } = Astro.props;
const payload = await getPayload(Astro);
if (payload) story = payload.story;
---

<SolutionSubPage>
  <StoryblokComponent blok={story.content} />
</SolutionSubPage>
