---
import { useStoryblokApi } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import SolutionSubPage from "../layouts/SolutionSubPage.astro";

// SSR: Story pro Request anhand des Slugs laden (getStaticPaths wird unter
// output: "server" ignoriert). Slugs mit eigener Route auslassen (index.astro
// -> "home", komponenten.astro), damit keine doppelten Routen entstehen.
const { slug } = Astro.params;
const reserved = new Set(["home", "komponenten"]);

if (!slug || reserved.has(slug)) {
  return new Response(null, { status: 404 });
}

const isPreview =
  import.meta.env.DEV || Astro.url.searchParams.has("_storyblok");

let story: any = null;
try {
  const storyblokApi = useStoryblokApi();
  const { data } = await storyblokApi.get(`cdn/stories/${slug}`, {
    version: isPreview ? "draft" : "published",
  });
  story = data.story;
} catch {
  // Story nicht gefunden oder Storyblok nicht erreichbar
}

if (!story) {
  return new Response(null, { status: 404 });
}
---

<SolutionSubPage>
  <StoryblokComponent blok={story.content} />
</SolutionSubPage>
