---

<SolutionSubPage>
  <!-- Übersichts-Header + Inhaltsverzeichnis -->
  <header class="ko-header">
    <div class="ko-header-inner">
      <span class="ko-kicker">Referenz</span>
      <h1 class="ko-title">SubPage-Komponenten</h1>
      <p class="ko-lead">
        Alle verfügbaren Storyblok-Blöcke für Subpages – mit Beispieldaten gerendert.
        Klicken Sie auf einen Block, um direkt dorthin zu springen.
      </p>
      <nav class="ko-toc" aria-label="Komponenten">
        {sample.map((s) => (
          <a href={`#${s.id}`} class="ko-toc-link">{s.label}</a>
        ))}
      </nav>
    </div>
  </header>

  {sample.map((s) => (
    <>
      <div class="ko-marker" id={s.id}>
        <div class="ko-marker-inner">
          <code class="ko-code">{s.blok.component}</code>
          <div class="ko-marker-text">
            <span class="ko-marker-label">{s.label}</span>
            <span class="ko-marker-desc">{s.desc}</span>
          </div>
        </div>
      </div>
      <StoryblokComponent blok={s.blok} />
    </>
  ))}
</SolutionSubPage>

<style>
  .ko-header {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: linear-gradient(180deg, #0a1628 0%, #0f2540 100%);
    color: #fff;
    padding: clamp(5rem, 9vw, 7rem) clamp(1.5rem, 6vw, 4rem) clamp(3rem, 5vw, 4rem);
  }
  .ko-header-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .ko-kicker {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #60b8ff;
  }
  .ko-title {
    margin: 0.75rem 0 0;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }
  .ko-lead {
    margin: 1.1rem 0 0;
    max-width: 56ch;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(200, 222, 245, 0.75);
  }
  .ko-toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 2rem;
  }
  .ko-toc-link {
    font-size: 13px;
    font-weight: 600;
    color: #cfe4fb;
    text-decoration: none;
    padding: 0.4rem 0.9rem;
    border-radius: 9999px;
    border: 1px solid rgba(96, 184, 255, 0.3);
    background: rgba(56, 168, 255, 0.08);
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .ko-toc-link:hover {
    background: rgba(56, 168, 255, 0.2);
    border-color: rgba(96, 184, 255, 0.6);
  }

  /* Label-Streifen vor jeder Komponente */
  .ko-marker {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: #f1f5f9;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
    scroll-margin-top: 1rem;
  }
  .ko-marker-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem clamp(1.5rem, 6vw, 4rem);
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .ko-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    font-weight: 600;
    color: #2563eb;
    background: #fff;
    border: 1px solid #dbe5f2;
    border-radius: 7px;
    padding: 0.3rem 0.6rem;
    white-space: nowrap;
    flex: none;
  }
  .ko-marker-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .ko-marker-label {
    font-size: 14px;
    font-weight: 700;
    color: #0a1628;
  }
  .ko-marker-desc {
    font-size: 13px;
    color: #64748b;
    line-height: 1.4;
  }
</style>
