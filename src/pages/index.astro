---
import "../assets/app.css";
import { useStoryblokApi } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import Navbar from "../components/Navbar/Navbar.astro";
import Hero from "../components/Hero.astro";
import Company from "../components/Company.astro";
import Solutions from "../components/Solutions.astro";
import Industries from "../components/Industries.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/Banners/CTA.astro";
import Footer from "../components/Footer.astro";
import Management from "../components/Management.astro";

let storyContent: any = null;

try {
  const storyblokApi = useStoryblokApi();
  const { data } = await storyblokApi.get("cdn/stories/home", {
    version: import.meta.env.DEV ? "draft" : "published",
  });
  storyContent = data.story.content;
} catch {
  // Story nicht erreichbar → Fallback auf hardcoded Defaults
}
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>AI-driven Platform for Enterprises & Telcos | CreaLog</title>
  </head>
  <body>
    <Navbar />
    {storyContent ? (
      <>
        {["hero", "company", "management"].map((type) => {
          const blok = storyContent.body?.find((b: any) => b.component === type);
          return blok ? <StoryblokComponent blok={blok} /> : null;
        })}
      </>
    ) : (
      <>
        <Hero />
        <Company />
        <Management />
      </>
    )}
    <Solutions />
    <Industries />
    <Testimonials />
    <CTA />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
