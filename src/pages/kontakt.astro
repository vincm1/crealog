---
// Kontakt — nutzt den wiederverwendbaren ContactCta-Block (Brevo-Newsletter-
// Formular, Crealog-gestylt). Die gesamte Formular-/Brevo-Logik liegt in der
// Komponente, damit sie auch als Storyblok-CTA auf anderen Seiten einsetzbar
// ist (eine Quelle, DRY).
import LandingLayout from "../layouts/LandingLayout.astro";
import ContactCta from "../storyblok/cta/ContactCta.astro";
---

<LandingLayout
  title="Kontakt | CreaLog"
  description="Nehmen Sie Kontakt mit CreaLog auf und bleiben Sie mit unserem Newsletter zu KI-gestützten Sprachlösungen auf dem Laufenden."
  darkHero={false}
>
  <main>
    <!-- Barrierefreie Seiten-H1; die sichtbare Überschrift der CTA ist eine H2. -->
    <h1 class="sr-only">Kontakt aufnehmen</h1>
    <ContactCta
      blok={{
        eyebrow: "Kontakt",
        headline: "Kontakt aufnehmen",
        subline:
          "Melden Sie sich für unseren Newsletter an und erhalten Sie Neuigkeiten zu KI-gestützten Sprachlösungen direkt in Ihr Postfach.",
      }}
    />
  </main>
</LandingLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
