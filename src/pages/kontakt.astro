---
// Kontakt — kurzer Intro-Header + Brevo-Newsletter-Formular (Inline-Embed).
//
// Das Formular ist der native Brevo-"end-form"-Embed: Brevos main.js übernimmt
// Validierung, DSGVO-Opt-in, Honeypot (email_address_check) und den AJAX-POST
// an die sibforms-action-URL. Wir laden Brevos sib-styles.css + main.js
// unverändert, entfernen aber Brevos graue Helvetica-Inline-Optik und legen
// per `<style is:global>` (unter `.kf`) das Crealog-Design darüber (Poppins,
// Crealog-Blau #004081, abgerundete Inputs, Card). Funktionale Attribute
// (ids, names, classes, hidden inputs, action) bleiben unverändert.
import LandingLayout from "../layouts/LandingLayout.astro";

const FORM_ACTION =
  "https://35f86a8e.sibforms.com/v2/serve/MUIFALM8bznZEkKLZKD9AE-e421X7vMxykwdGIhR6_daL5IuviLHDfozJDRPYdoCI4iJ_kliT4XDORbcArTX_WSNFgsihxenp34-_hIVv7yHnCzVPQtIKyjpZ_hERCrbIrlSyeU_6WzuGSHjI06QucmszMxZjIoM6lKdANyvDs3DP-lvP5ZF5Dvu30pvWEyZhDSzhULLnl7V2ygdvw==";
---

<LandingLayout
  title="Kontakt | CreaLog"
  description="Nehmen Sie Kontakt mit CreaLog auf und bleiben Sie mit unserem Newsletter zu KI-gestützten Sprachlösungen auf dem Laufenden."
  darkHero={false}
>
  <main class="kontakt">
    <!-- Intro-Header -->
    <header class="kontakt__header">
      <span class="kontakt__eyebrow">Kontakt</span>
      <h1 class="kontakt__title">Kontakt aufnehmen</h1>
      <p class="kontakt__lead">
        Melden Sie sich für unseren Newsletter an und erhalten Sie Neuigkeiten
        zu KI-gestützten Sprachlösungen direkt in Ihr Postfach.
      </p>
    </header>

    <!-- Brevo-Formular (Inline-Embed), Crealog-gestylt via `.kf` -->
    <div class="kf">
      <div class="sib-form">
        <div id="sib-form-container" class="sib-form-container">
          <div
            id="error-message"
            class="sib-form-message-panel"
          >
            <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
              <svg viewBox="0 0 512 512" class="sib-icon sib-notification__icon">
                <path d="M256 40c118.621 0 216 96.075 216 216 0 119.291-96.61 216-216 216-119.244 0-216-96.562-216-216 0-119.203 96.602-216 216-216m0-32C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm-11.49 120h22.979c6.823 0 12.274 5.682 11.99 12.5l-7 168c-.268 6.428-5.556 11.5-11.99 11.5h-8.979c-6.433 0-11.722-5.073-11.99-11.5l-7-168c-.283-6.818 5.167-12.5 11.99-12.5zM256 340c-15.464 0-28 12.536-28 28s12.536 28 28 28 28-12.536 28-28-12.536-28-28-28z"></path>
              </svg>
              <span class="sib-form-message-panel__inner-text">
                Ihre Anmeldung konnte nicht gespeichert werden. Bitte versuchen Sie es erneut.
              </span>
            </div>
          </div>

          <div
            id="success-message"
            class="sib-form-message-panel"
          >
            <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
              <svg viewBox="0 0 512 512" class="sib-icon sib-notification__icon">
                <path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 464c-118.664 0-216-96.055-216-216 0-118.663 96.055-216 216-216 118.664 0 216 96.055 216 216 0 118.663-96.055 216-216 216zm141.63-274.961L217.15 376.071c-4.705 4.667-12.303 4.637-16.97-.068l-85.878-86.572c-4.667-4.705-4.637-12.303.068-16.97l8.52-8.451c4.705-4.667 12.303-4.637 16.97.068l68.976 69.533 163.441-162.13c4.705-4.667 12.303-4.637 16.97.068l8.451 8.52c4.668 4.705 4.637 12.303-.068 16.97z"></path>
              </svg>
              <span class="sib-form-message-panel__inner-text">
                Ihre Anmeldung war erfolgreich.
              </span>
            </div>
          </div>

          <div id="sib-container" class="sib-container--large sib-container--vertical">
            <form
              id="sib-form"
              method="POST"
              action={FORM_ACTION}
              data-type="subscription"
            >
              <!-- E-Mail -->
              <div class="kf-field">
                <div class="sib-input sib-form-block">
                  <div class="form__entry entry_block">
                    <div class="form__label-row">
                      <label class="entry__label" for="EMAIL" data-required="*">
                        E-Mail-Adresse
                      </label>
                      <div class="entry__field">
                        <input
                          class="input"
                          type="text"
                          id="EMAIL"
                          name="EMAIL"
                          autocomplete="email"
                          value=""
                          placeholder="name@unternehmen.de"
                          data-required="true"
                          required
                        />
                      </div>
                    </div>
                    <label class="entry__error entry__error--primary"></label>
                    <label class="entry__specification">
                      z. B. name@unternehmen.de
                    </label>
                  </div>
                </div>
              </div>

              <!-- Unternehmen -->
              <div class="kf-field">
                <div class="sib-input sib-form-block">
                  <div class="form__entry entry_block">
                    <div class="form__label-row">
                      <label class="entry__label" for="name" data-required="*">
                        Unternehmen
                      </label>
                      <div class="entry__field">
                        <input
                          class="input"
                          maxlength="200"
                          type="text"
                          id="name"
                          name="COMPANY:name"
                          autocomplete="organization"
                          placeholder="Ihr Unternehmen"
                          data-required="true"
                          required
                        />
                      </div>
                    </div>
                    <label class="entry__error entry__error--primary"></label>
                  </div>
                </div>
              </div>

              <!-- Trenner -->
              <div class="sib-form-block sib-divider-form-block">
                <div class="kf-divider"></div>
              </div>

              <!-- DSGVO-Hinweis (Brevo, Pflicht) -->
              <div class="sib-form__declaration">
                <div class="kf-declaration-text">
                  <p>
                    Wir verwenden Brevo als unsere Marketing-Plattform. Indem Sie
                    das Formular absenden, erklären Sie sich einverstanden, dass
                    die von Ihnen angegebenen persönlichen Informationen an Brevo
                    zur Bearbeitung übertragen werden gemäß der
                    <a
                      href="https://www.brevo.com/de/legal/privacypolicy/"
                      target="_blank"
                      rel="nofollow noopener"
                    >Datenschutzerklärung von Brevo</a>.
                  </p>
                </div>
              </div>

              <!-- Opt-in -->
              <div class="sib-optin sib-form-block" data-required="true">
                <div class="form__entry entry_mcq">
                  <div class="form__label-row">
                    <div class="entry__choice">
                      <label class="kf-optin-label">
                        <input
                          type="checkbox"
                          class="input_replaced"
                          value="1"
                          id="NEWSLETTER_CONSENT"
                          name="NEWSLETTER_CONSENT"
                          required
                        />
                        <span class="checkbox checkbox_tick_positive"></span>
                        <span class="kf-optin-text">
                          Ich möchte Ihren Newsletter erhalten und akzeptiere die
                          Datenschutzerklärung.
                        </span>
                      </label>
                    </div>
                  </div>
                  <label class="entry__error entry__error--primary"></label>
                  <label class="entry__specification">
                    Sie können den Newsletter jederzeit über den Link in unserem
                    Newsletter abbestellen.
                  </label>
                </div>
              </div>

              <!-- Absenden -->
              <div class="sib-form-block kf-submit">
                <button
                  class="sib-form-block__button sib-form-block__button-with-loader"
                  form="sib-form"
                  type="submit"
                >
                  <svg
                    class="icon clickable__icon progress-indicator__icon sib-hide-loader-icon"
                    viewBox="0 0 512 512"
                  >
                    <path d="M460.116 373.846l-20.823-12.022c-5.541-3.199-7.54-10.159-4.663-15.874 30.137-59.886 28.343-131.652-5.386-189.946-33.641-58.394-94.896-95.833-161.827-99.676C261.028 55.961 256 50.751 256 44.352V20.309c0-6.904 5.808-12.337 12.703-11.982 83.556 4.306 160.163 50.864 202.11 123.677 42.063 72.696 44.079 162.316 6.031 236.832-3.14 6.148-10.75 8.461-16.728 5.01z"></path>
                  </svg>
                  Anmelden
                </button>
              </div>

              <!-- Honeypot + locale (Brevo, nicht entfernen) -->
              <input
                type="text"
                name="email_address_check"
                value=""
                class="input--hidden"
              />
              <input type="hidden" name="locale" value="de" />
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
</LandingLayout>

<!-- Brevos Stylesheet (Checkbox-Rendering, Message-Panels, Loader) -->
<link
  is:inline
  rel="stylesheet"
  href="https://sibforms.com/forms/end-form/build/sib-styles.css"
/>

<!-- Brevo-Config + main.js: Validierung, Opt-in, AJAX-Submit. is:inline,
     damit Astro sie unverändert lässt. Reihenfolge (Config vor main.js)
     muss erhalten bleiben. -->
<script is:inline>
  window.REQUIRED_CODE_ERROR_MESSAGE = "Wählen Sie bitte eine Ländervorwahl aus.";
  window.LOCALE = "de";
  window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE =
    "Die eingegebenen Informationen sind nicht gültig. Bitte überprüfen Sie das Feldformat und versuchen Sie es erneut.";
  window.REQUIRED_ERROR_MESSAGE = "Dieses Feld darf nicht leer sein. ";
  window.GENERIC_INVALID_MESSAGE =
    "Die eingegebenen Informationen sind nicht gültig. Bitte überprüfen Sie das Feldformat und versuchen Sie es erneut.";
  window.INVALID_NUMBER =
    "Die eingegebenen Informationen sind nicht gültig. Bitte überprüfen Sie das Feldformat und versuchen Sie es erneut.";
  window.INVALID_DATE = "Bitte geben Sie ein gültiges Datum ein";
  window.REQUIRED_MULTISELECT_MESSAGE = "Wählen Sie bitte mindestens eine Option aus";
  window.translation = {
    common: {
      selectedList: "{quantity} Liste ausgewählt",
      selectedLists: "{quantity} Listen ausgewählt",
      selectedOption: "{quantity} ausgewählt",
      selectedOptions: "{quantity} ausgewählt",
    },
  };
  var AUTOHIDE = Boolean(0);
</script>
<script is:inline defer src="https://sibforms.com/forms/end-form/build/main.js"></script>

<style>
  /* Seiten-Rahmen (scoped) */
  .kontakt {
    font-family: "Poppins", Calibri, sans-serif;
    background: linear-gradient(180deg, #f7faff 0%, #eef3fb 100%);
    min-height: 70vh;
    padding: clamp(4.5rem, 8vw, 7rem) 1.5rem clamp(4rem, 8vw, 6rem);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .kontakt__header {
    max-width: 40rem;
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .kontakt__eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #004081;
    margin-bottom: 0.9rem;
  }

  .kontakt__title {
    margin: 0;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #0a1628;
  }

  .kontakt__lead {
    margin: 1.1rem auto 0;
    max-width: 34rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #4b5563;
  }
</style>

<!-- Crealog-Overrides für das Brevo-Formular (global, da Brevo globale
     Klassen nutzt). `.kf`-Präfix + !important schlagen Brevos Inline-Styles. -->
<style is:global>
  .kf {
    width: 100%;
    max-width: 560px;
  }

  .kf .sib-form {
    padding: 0 !important;
    background: transparent !important;
    text-align: left !important;
  }

  .kf #sib-container {
    max-width: 100% !important;
    padding: clamp(1.75rem, 4vw, 2.75rem) !important;
    background: #ffffff !important;
    border: 1px solid #eaeff5 !important;
    border-radius: 24px !important;
    box-shadow: 0 18px 50px -24px rgba(0, 64, 129, 0.25) !important;
    direction: ltr;
  }

  .kf .kf-field {
    margin-bottom: 1.15rem;
  }

  .kf .entry__label {
    display: block;
    margin-bottom: 0.45rem;
    font-family: "Poppins", Calibri, sans-serif !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    color: #0f1e30 !important;
    text-align: left !important;
  }

  .kf .input {
    width: 100%;
    box-sizing: border-box;
    font-family: "Poppins", Calibri, sans-serif !important;
    font-size: 15px !important;
    color: #0f1e30 !important;
    background: #ffffff !important;
    border: 1px solid #d5deea !important;
    border-radius: 12px !important;
    padding: 0.8rem 1rem !important;
    box-shadow: none !important;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .kf .input::placeholder {
    color: #9aa8bd !important;
    font-family: "Poppins", Calibri, sans-serif !important;
  }

  .kf .input:focus {
    outline: none !important;
    border-color: #004081 !important;
    box-shadow: 0 0 0 3px rgba(0, 64, 129, 0.12) !important;
  }

  .kf .entry__specification {
    display: block;
    margin-top: 0.4rem;
    font-family: "Poppins", Calibri, sans-serif !important;
    font-size: 12.5px !important;
    color: #64748b !important;
    text-align: left !important;
  }

  .kf .entry__error {
    font-family: "Poppins", Calibri, sans-serif !important;
    font-size: 13px !important;
    border-radius: 8px !important;
  }

  /* Trenner */
  .kf .sib-divider-form-block {
    padding: 0.35rem 0 1.1rem;
  }
  .kf .kf-divider {
    border: 0;
    border-bottom: 1px solid #e5edf6;
  }

  /* DSGVO-Hinweis */
  .kf .sib-form__declaration {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }
  .kf .kf-declaration-text p {
    margin: 0;
    font-family: "Poppins", Calibri, sans-serif !important;
    font-size: 13px !important;
    line-height: 1.6 !important;
    color: #687484 !important;
  }
  .kf .kf-declaration-text a {
    color: #004081 !important;
    text-decoration: underline;
  }

  /* Opt-in */
  .kf .sib-optin {
    margin-bottom: 1.4rem;
  }
  .kf .kf-optin-label {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    cursor: pointer;
  }
  .kf .kf-optin-text p,
  .kf .kf-optin-text {
    margin: 0;
    font-family: "Poppins", Calibri, sans-serif !important;
    font-size: 13.5px !important;
    line-height: 1.55 !important;
    color: #3c4858 !important;
  }
  /* Brevos Custom-Checkbox in Crealog-Blau umfärben */
  .kf input:checked ~ .checkbox_tick_positive,
  .kf .checkbox_tick_positive {
    accent-color: #004081;
  }

  /* Absenden-Button */
  .kf .kf-submit {
    text-align: left;
  }
  .kf .sib-form-block__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Poppins", Calibri, sans-serif !important;
    font-size: 15px !important;
    font-weight: 600 !important;
    color: #ffffff !important;
    background: #004081 !important;
    border: 0 !important;
    border-radius: 12px !important;
    padding: 0.85rem 1.9rem !important;
    cursor: pointer;
    box-shadow: 0 8px 20px -8px rgba(0, 64, 129, 0.55) !important;
    transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }
  .kf .sib-form-block__button:hover {
    background: #013a73 !important;
    transform: translateY(-1px);
    box-shadow: 0 12px 26px -8px rgba(0, 64, 129, 0.6) !important;
  }

  /* Message-Panels (Brevo blendet sie per JS ein) */
  .kf .sib-form-message-panel {
    font-family: "Poppins", Calibri, sans-serif !important;
    max-width: 100% !important;
    border-radius: 12px !important;
    margin-bottom: 1.1rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .kf .sib-form-block__button,
    .kf .input {
      transition: none !important;
    }
    .kf .sib-form-block__button:hover {
      transform: none;
    }
  }
</style>
