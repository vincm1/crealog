---
import "../../assets/app.css";
import Navbar from "../../components/Navbar/Navbar.astro";
import Footer from "../../components/Footer.astro";

const stats = [
  { value: "99.999%", label: "Verfügbarkeit" },
  { value: "< 5 ms", label: "Signalisierungslatenz" },
  { value: "1 Mio.+", label: "Simultane Sessions" },
  { value: "DSGVO", label: "Konform & Made in DE" },
];

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    title: "Service Orchestration",
    desc: "Flexible Dienstekomposition und -verkettung in Echtzeit. Serviceketten visuell konfigurieren — ohne Code-Änderungen.",
    tags: ["Visual Builder", "Event-driven"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 1.046a1 1 0 01.7 1.215L10.06 9H16a1 1 0 01.78 1.625l-9 11A1 1 0 016 21l1.94-7H2a1 1 0 01-.78-1.625l9-11a1 1 0 01.08-.329z"/></svg>`,
    title: "Real-time Charging (OCS)",
    desc: "Vollintegriertes Online Charging System für präzise Prepaid- und Postpaid-Abrechnung auf Session-Ebene.",
    tags: ["Gy Interface", "Diameter"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    title: "API Gateway",
    desc: "Netzwerkfähigkeiten als REST-APIs für CPaaS-Szenarien, Partner-Portale und Self-Service-Anwendungen.",
    tags: ["REST / OpenAPI 3.0", "Webhook"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5l-3.9 19.5m-2.1-19.5l-3.9 19.5"/></svg>`,
    title: "Rufnummernmanagement",
    desc: "Carrier-grade DID-Verwaltung, Rufnummernportierung (LNP/MNP) und intelligentes Routing europaweit.",
    tags: ["DID / DDI", "LNP · MNP"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Fraud Protection",
    desc: "KI-basierte Echtzeiterkennung von Toll-Fraud, Spoofing und anomalen Verkehrsmustern — proaktiv, nicht reaktiv.",
    tags: ["ML-Modelle", "Auto-Blocking"],
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
    title: "Live Analytics & CDR",
    desc: "Vollständige CDR-Auswertung, Qualitäts-KPIs und Kapazitätsplanung — live, ohne Batch-Verzögerung.",
    tags: ["Real-time CDR", "KPI Dashboard"],
  },
];

const layers = [
  {
    level: "01",
    name: "Application Layer",
    color: "#1d4ed8",
    items: ["Partner API Portal", "Self-Service Management Console", "Analytics & Reporting Dashboard", "Billing & Invoice Export"],
  },
  {
    level: "02",
    name: "Service Engine",
    color: "#0369a1",
    items: ["Service Orchestrator", "Online Charging System (OCS)", "Number Registry & Router", "Fraud Detection Engine"],
  },
  {
    level: "03",
    name: "Network Layer",
    color: "#004990",
    items: ["SIP / SIP-T Signalisierung", "SIGTRAN / SS7 / ISUP", "RTP / SRTP Media", "Carrier Interconnect"],
  },
];

const specs = [
  { label: "Verfügbarkeit", value: "99.999 % SLA (< 5,3 min/Jahr)" },
  { label: "Latenz", value: "< 5 ms End-to-End Signalisierung" },
  { label: "Kapazität", value: "1 Mio.+ simultane Sessions" },
  { label: "Protokolle", value: "SIP, SIP-T, SIGTRAN, SS7/ISUP, RTP/SRTP" },
  { label: "APIs", value: "REST/JSON, OpenAPI 3.0, Webhooks" },
  { label: "Deployment", value: "On-Premise · Private Cloud · Hybrid" },
  { label: "Clustering", value: "Active-Active, georedundant" },
  { label: "Zertifizierungen", value: "ISO 27001 · DSGVO · TÜV-geprüft" },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Service Delivery Platform | CreaLog Telco Solutions</title>
  </head>
  <body class="sdp-page">
    <Navbar />

    <!-- ── Hero ──────────────────────────────────────────────────────────── -->
    <section class="sdp-hero">
      <div class="sdp-container">
        <div class="sdp-hero__inner">
          <div class="sdp-hero__left">
            <!-- Breadcrumb -->
            <nav class="sdp-breadcrumb">
              <a href="/">CreaLog</a>
              <span>›</span>
              <a href="/telco-solutions">Telco Solutions</a>
              <span>›</span>
              <span>Service Delivery Platform</span>
            </nav>

            <!-- Badge -->
            <span class="sdp-badge">
              <span class="sdp-badge__dot"></span>
              Carrier Infrastructure
            </span>

            <!-- Headline -->
            <h1 class="sdp-hero__h1">
              Service Delivery<br />
              <span class="sdp-hero__accent">Platform</span>
            </h1>

            <p class="sdp-hero__sub">
              Next-generation Middleware für moderne Carrier. Erstellen, verwalten und monetarisieren Sie Telco-Dienste mit carrier-grade Zuverlässigkeit — on-premise oder in der Cloud.
            </p>

            <!-- CTAs -->
            <div class="sdp-hero__ctas">
              <a href="/kontakt" class="sdp-btn sdp-btn--primary">
                Demo vereinbaren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </a>
              <a href="/kontakt" class="sdp-btn sdp-btn--outline">
                Datenblatt anfordern
              </a>
            </div>

            <!-- Stats -->
            <div class="sdp-hero__stats">
              {stats.map((s, i) => (
                <>
                  {i > 0 && <div class="sdp-stat-divider" />}
                  <div class="sdp-stat">
                    <span class="sdp-stat__val">{s.value}</span>
                    <span class="sdp-stat__label">{s.label}</span>
                  </div>
                </>
              ))}
            </div>
          </div>

          <!-- Right: Architecture preview -->
          <div class="sdp-hero__right" aria-hidden="true">
            <div class="sdp-preview">
              <div class="sdp-preview__bar"><i></i><i></i><i></i></div>
              <div class="sdp-preview__body">
                <div class="sdp-preview__label">SDP — Live Status</div>
                {[
                  { name: "Service Orchestrator", status: "active", load: 42 },
                  { name: "OCS / Charging Engine", status: "active", load: 67 },
                  { name: "API Gateway", status: "active", load: 31 },
                  { name: "Fraud Detection", status: "active", load: 18 },
                ].map((row) => (
                  <div class="sdp-row">
                    <span class="sdp-row__dot" />
                    <span class="sdp-row__name">{row.name}</span>
                    <div class="sdp-row__bar">
                      <div class="sdp-row__fill" style={`width:${row.load}%`} />
                    </div>
                    <span class="sdp-row__pct">{row.load}%</span>
                  </div>
                ))}
                <div class="sdp-preview__footer">
                  <span class="sdp-live"><span class="sdp-live__dot" />Live</span>
                  <span>1 021 342 Sessions aktiv</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Features ──────────────────────────────────────────────────────── -->
    <section class="sdp-features">
      <div class="sdp-container">
        <div class="sdp-sec-head">
          <span class="sdp-eyebrow">Funktionsumfang</span>
          <h2 class="sdp-sec-title">Alles aus einer Plattform</h2>
          <p class="sdp-sec-sub">Sechs integrierte Module — carrier-grade, skalierbar, API-first.</p>
        </div>
        <div class="sdp-feat-grid">
          {features.map((f) => (
            <div class="sdp-feat-card">
              <div class="sdp-feat-card__icon" set:html={f.icon} />
              <h3 class="sdp-feat-card__title">{f.title}</h3>
              <p class="sdp-feat-card__desc">{f.desc}</p>
              <div class="sdp-feat-card__tags">
                {f.tags.map((t) => <span class="sdp-tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Architecture ──────────────────────────────────────────────────── -->
    <section class="sdp-arch">
      <div class="sdp-container">
        <div class="sdp-sec-head">
          <span class="sdp-eyebrow">Plattform-Architektur</span>
          <h2 class="sdp-sec-title">Drei integrierte Schichten</h2>
          <p class="sdp-sec-sub">Vom Netzwerk bis zur Applikation — eine kohärente, offene Plattform.</p>
        </div>
        <div class="sdp-arch-layers">
          {layers.map((l) => (
            <div class="sdp-arch-layer">
              <div class="sdp-arch-layer__head" style={`border-left: 3px solid ${l.color};`}>
                <span class="sdp-arch-layer__num" style={`color: ${l.color};`}>{l.level}</span>
                <span class="sdp-arch-layer__name">{l.name}</span>
              </div>
              <div class="sdp-arch-layer__items">
                {l.items.map((item) => (
                  <span class="sdp-arch-item">
                    <svg class="sdp-arch-check" viewBox="0 0 20 20" fill="currentColor" style={`color: ${l.color};`}><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Specs ─────────────────────────────────────────────────────────── -->
    <section class="sdp-specs">
      <div class="sdp-container">
        <div class="sdp-specs__inner">
          <div class="sdp-specs__left">
            <span class="sdp-eyebrow">Technische Spezifikationen</span>
            <h2 class="sdp-sec-title sdp-specs__title">Carrier-grade,<br />von Grund auf</h2>
            <p class="sdp-sec-sub" style="text-align:left; max-width:340px;">
              Entwickelt für den Betrieb in nationalen Telekommunikationsnetzen — mit den höchsten Anforderungen an Verfügbarkeit, Latenz und Skalierbarkeit.
            </p>
            <div class="sdp-specs__badges">
              <span class="sdp-sbadge">ISO 27001</span>
              <span class="sdp-sbadge">DSGVO</span>
              <span class="sdp-sbadge">TÜV-geprüft</span>
              <span class="sdp-sbadge">Made in Germany</span>
            </div>
          </div>
          <div class="sdp-specs__right">
            {specs.map((s) => (
              <div class="sdp-spec-row">
                <span class="sdp-spec-row__label">{s.label}</span>
                <span class="sdp-spec-row__value">{s.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────────────────────────── -->
    <section class="sdp-cta">
      <div class="sdp-container">
        <div class="sdp-cta__inner">
          <h2 class="sdp-cta__title">Bereit für den nächsten Schritt?</h2>
          <p class="sdp-cta__sub">Sprechen Sie mit einem unserer Telco-Experten oder fordern Sie direkt das technische Datenblatt an.</p>
          <div class="sdp-cta__btns">
            <a href="/kontakt" class="sdp-btn sdp-btn--primary">Demo vereinbaren →</a>
            <a href="/kontakt" class="sdp-btn sdp-btn--outline">Datenblatt anfordern</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  .sdp-page {
    font-family: "Plus Jakarta Sans", sans-serif;
    margin: 0;
    background: #fff;
  }

  .sdp-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 1024px) { .sdp-container { padding: 0 2.5rem; } }

  /* ── shared section header ── */
  .sdp-sec-head { text-align: center; margin-bottom: 3rem; }
  .sdp-eyebrow {
    display: inline-block;
    color: #1d4ed8;
    font-size: 11.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    margin-bottom: 0.75rem;
  }
  .sdp-sec-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #09090b;
    margin: 0 0 0.75rem;
  }
  .sdp-sec-sub {
    font-size: 15px;
    line-height: 1.7;
    color: #5b6472;
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
  }

  /* ── hero ── */
  .sdp-hero {
    padding: 7rem 0 4rem;
    background: linear-gradient(160deg, #f0f5ff 0%, #ffffff 55%);
    border-bottom: 1px solid #e6e8ec;
  }
  .sdp-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .sdp-hero__inner { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }

  .sdp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
    color: #9ca3af;
    margin-bottom: 1.25rem;
  }
  .sdp-breadcrumb a { color: #6b7280; text-decoration: none; }
  .sdp-breadcrumb a:hover { color: #1d4ed8; }

  .sdp-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #eff4ff;
    color: #1d4ed8;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.35rem 0.9rem;
    border-radius: 99px;
    margin-bottom: 1.5rem;
  }
  .sdp-badge__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #1d4ed8;
    animation: sdpPulse 1.6s ease-in-out infinite;
  }
  @keyframes sdpPulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .sdp-hero__h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #09090b;
    margin: 0 0 1.25rem;
  }
  .sdp-hero__accent { color: #1d4ed8; }
  .sdp-hero__sub {
    font-size: 16px;
    line-height: 1.7;
    color: #5b6472;
    max-width: 460px;
    margin-bottom: 2rem;
  }

  .sdp-hero__ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }

  .sdp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 14px;
    font-weight: 600;
    padding: 0.8rem 1.6rem;
    border-radius: 99px;
    text-decoration: none;
    transition: all 0.22s cubic-bezier(0.22,1,0.36,1);
    border: none;
    cursor: pointer;
  }
  .sdp-btn--primary {
    background: #09090b;
    color: #fff;
  }
  .sdp-btn--primary:hover { background: #18181b; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(29,78,216,0.25); }
  .sdp-btn--outline {
    background: #fff;
    color: #3f3f46;
    border: 1.5px solid #e4e4e7;
  }
  .sdp-btn--outline:hover { border-color: #09090b; background: #f4f4f5; transform: translateY(-2px); }

  .sdp-hero__stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    padding-top: 1.5rem;
    border-top: 1px solid #e6e8ec;
  }
  .sdp-stat { display: flex; flex-direction: column; gap: 2px; padding: 0 1.25rem 0 0; }
  .sdp-stat:first-child { padding-left: 0; }
  .sdp-stat__val { font-size: 1.15rem; font-weight: 700; color: #004990; letter-spacing: -0.01em; }
  .sdp-stat__label { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.12em; color: #9ca3af; }
  .sdp-stat-divider { width: 1px; height: 28px; background: #e2e8f0; margin: 0 1.25rem; }

  /* preview card */
  .sdp-hero__right { display: flex; justify-content: center; }
  .sdp-preview {
    width: 100%;
    max-width: 400px;
    background: #0e1929;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 32px 64px -24px rgba(15,23,42,0.4);
  }
  .sdp-preview__bar {
    display: flex; gap: 6px; padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .sdp-preview__bar i { width: 9px; height: 9px; border-radius: 50%; background: rgba(255,255,255,0.12); }
  .sdp-preview__body { padding: 1.25rem; display: flex; flex-direction: column; gap: 10px; }
  .sdp-preview__label { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: rgba(255,255,255,0.3); margin-bottom: 4px; }
  .sdp-row { display: flex; align-items: center; gap: 8px; }
  .sdp-row__dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; flex-shrink: 0; }
  .sdp-row__name { font-size: 12px; color: rgba(255,255,255,0.7); flex: 1; white-space: nowrap; }
  .sdp-row__bar { flex: 1; height: 4px; background: rgba(255,255,255,0.08); border-radius: 99px; overflow: hidden; }
  .sdp-row__fill { height: 100%; background: linear-gradient(90deg, #2f6bff, #60a5fa); border-radius: 99px; }
  .sdp-row__pct { font-size: 11px; color: rgba(255,255,255,0.35); width: 28px; text-align: right; }
  .sdp-preview__footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 4px; padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 11px; color: rgba(255,255,255,0.3);
  }
  .sdp-live { display: flex; align-items: center; gap: 5px; color: #22c55e; font-weight: 600; }
  .sdp-live__dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; animation: sdpPulse 1.4s ease-in-out infinite; }

  /* ── features ── */
  .sdp-features { padding: 5rem 0; background: #fff; }
  .sdp-feat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) { .sdp-feat-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .sdp-feat-grid { grid-template-columns: repeat(3, 1fr); } }

  .sdp-feat-card {
    padding: 28px;
    border: 1px solid #e6e8ec;
    border-radius: 16px;
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .sdp-feat-card:hover { border-color: #1d4ed8; transform: translateY(-3px); box-shadow: 0 8px 24px rgba(29,78,216,0.08); }
  .sdp-feat-card__icon {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 12px;
    background: linear-gradient(145deg, #3b82f6 0%, #1d4ed8 100%);
    color: #fff;
    flex-shrink: 0;
  }
  .sdp-feat-card__icon :global(svg) { width: 22px; height: 22px; }
  .sdp-feat-card__title { font-size: 15px; font-weight: 700; color: #09090b; margin: 0; }
  .sdp-feat-card__desc { font-size: 13.5px; line-height: 1.65; color: #5b6472; margin: 0; flex: 1; }
  .sdp-feat-card__tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: auto; }
  .sdp-tag {
    font-size: 10.5px; font-weight: 600; letter-spacing: 0.04em;
    background: #eff4ff; color: #1d4ed8;
    padding: 3px 9px; border-radius: 99px;
  }

  /* ── architecture ── */
  .sdp-arch { padding: 5rem 0; background: #f8faff; border-top: 1px solid #e6e8ec; border-bottom: 1px solid #e6e8ec; }
  .sdp-arch-layers { display: flex; flex-direction: column; gap: 14px; }

  .sdp-arch-layer {
    background: #fff;
    border: 1px solid #e6e8ec;
    border-radius: 16px;
    overflow: hidden;
  }
  .sdp-arch-layer__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
