---
import SolutionsStack from "./SolutionsStack.vue";
import CTAContact from "./Banners/CTA_contact.astro";
---

<section class="sol-section">
  <SolutionsStack client:visible />

  <div class="sol-cta-row">
    <CTAContact />
  </div>
</section>

<style>
  .sol-section {
    font-family: "Plus Jakarta Sans", sans-serif;
    background: #fff;
    padding-top: 3rem;
  }

  .sol-cta-row {
    max-width: 80rem;
    margin: 1rem auto 4rem;
    padding: 0 1.5rem;
  }
</style>
